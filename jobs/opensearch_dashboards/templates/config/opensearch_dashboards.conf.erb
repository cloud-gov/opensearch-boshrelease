#
# OpenSearch Dashboards Configuration
#
# This file configures the OpenSearch Dashboards server, its connection to OpenSearch,
# security settings, and branding. It uses ERB (Embedded Ruby) to dynamically
# pull configuration values from the BOSH deployment manifest properties (`p()`)
# and linked jobs (`if_link()`).
#
# Example config: https://github.com/opensearch-project/OpenSearch-Dashboards/blob/main/config/opensearch_dashboards.yml

# ==============================================================================
# 1. Server Configuration
#    Settings related to how the OpenSearch Dashboards server itself operates.
# ==============================================================================

# server.port: Specifies the port on which OpenSearch Dashboards will listen.
server.port: <%= p('opensearch_dashboards.port') %>

# server.host: Specifies the address to which the OpenSearch Dashboards server will bind.
# IP addresses and host names are both valid values.
# The default is 'localhost', which usually means remote machines will not be able to connect.
# To allow connections from remote users, set this parameter to a non-loopback address.
server.host: <%= p('opensearch_dashboards.host') %>

# ------------------------------------------------------------------------------
# 1.1 Server SSL Configuration (Dashboards <-> Browser)
# These settings enable SSL for incoming requests to the OpenSearch Dashboards server from a browser.
# ------------------------------------------------------------------------------

# server.ssl.enabled: Enables or disables SSL for the OpenSearch Dashboards server.
server.ssl.enabled: <%= p('opensearch_dashboards.server.ssl.enabled') %>

<% if_p('opensearch_dashboards.server.ssl.certificate') do %>
# server.ssl.certificate: Path to the PEM-format SSL certificate file for the Dashboards server.
server.ssl.certificate: /var/vcap/jobs/opensearch_dashboards/config/ssl/dashboard-web.crt
<% end %>

<% if_p('opensearch_dashboards.server.ssl.private_key') do %>
# server.ssl.key: Path to the PEM-format SSL private key file for the Dashboards server.
server.ssl.key: /var/vcap/jobs/opensearch_dashboards/config/ssl/dashboard-web.key
<% end %>

<% if_link("opensearch") do |opensearch_config| %>
  <% opensearch_config.if_p('opensearch.node.ssl.ca') do %>
# server.ssl.certificateAuthorities: Optional path(s) to PEM-format CA certificate files.
# These are used by the Dashboards server to verify client certificates, if client authentication is enabled.
server.ssl.certificateAuthorities: [ "/var/vcap/jobs/opensearch_dashboards/config/ssl/opensearch.ca" ]
  <% end %>
<% end %>

# ==============================================================================
# 2. OpenSearch Connection Configuration
#    Settings for how OpenSearch Dashboards connects to the OpenSearch cluster.
# ==============================================================================

<%
  # Determine the OpenSearch port:
  # First, attempt to get the port from a BOSH link named "opensearch".
  # If the link doesn't exist or doesn't provide the port, fall back to a
  # property defined directly in the opensearch_dashboards job manifest.
  opensearch_port = nil
  if_link("opensearch") { |opensearch_link| opensearch_port = opensearch_link.p("opensearch.port") }
  unless opensearch_port
    opensearch_port = p("opensearch_dashboards.opensearch.port")
  end
%>
# opensearch.hosts: Specifies the URL of the OpenSearch cluster that Dashboards will connect to.
# This uses HTTPS and constructs the URL from the host property and the dynamically determined port.
opensearch.hosts: "https://<%= p("opensearch_dashboards.opensearch.host") + ':' + opensearch_port.to_s %>"

# opensearch.preserveHost: If true, sends the hostname specified in `opensearch.hosts`.
# If false, sends the host used to connect to *this* OpenSearch Dashboards instance.
# opensearch.preserveHost: true

# opensearchDashboards.index: The name of the index in OpenSearch that Dashboards uses
# to store saved searches, visualizations, and dashboards. It will create this index
# if it doesn't already exist.
opensearchDashboards.index: <%= p('opensearch_dashboards.index') %>

# opensearchDashboards.defaultAppId: The default application to load when Dashboards starts.
# e.g., "discover", "dashboard", "visualize".
opensearchDashboards.defaultAppId: <%= p('opensearch_dashboards.defaultAppId') %>

# ==============================================================================
# 3. Branding Configuration
#    Customizes the look and feel of the OpenSearch Dashboards interface.
# ==============================================================================
opensearchDashboards.branding:
  # logo: Configuration for the main logo displayed in the header.
  logo:
    # defaultUrl: URL for the default logo image.
    defaultUrl: "https://raw.githubusercontent.com/cloud-gov/opensearch-boshrelease/refs/heads/main/src/images/cloud-gov%20logomark.svg"
    # darkModeUrl: URL for the logo image when dark mode is enabled.
    darkModeUrl: ""
  # mark: Configuration for the small mark/icon displayed alongside the logo.
  mark:
    # defaultUrl: URL for the default mark image.
    defaultUrl: "https://raw.githubusercontent.com/cloud-gov/opensearch-boshrelease/refs/heads/main/src/images/cloud-gov%20logomark.svg"
    # darkModeUrl: URL for the mark image when dark mode is enabled.
    darkModeUrl: "https://raw.githubusercontent.com/cloud-gov/opensearch-boshrelease/refs/heads/main/src/images/cloud-gov%20logomark.svg"
  # loadingLogo: Configuration for the logo displayed during initial loading.
  loadingLogo:
    # defaultUrl: URL for the default loading logo image (e.g., a GIF for animation).
    defaultUrl: "https://raw.githubusercontent.com/cloud-gov/opensearch-boshrelease/refs/heads/main/src/images/cloud-gov-spin.gif"
    # darkModeUrl: URL for the loading logo image when dark mode is enabled.
    darkModeUrl: ""
  # faviconUrl: URL for the favicon displayed in the browser tab.
  faviconUrl: "https://raw.githubusercontent.com/cloud-gov/opensearch-boshrelease/refs/heads/main/src/images/cloud-gov%20logomark.svg"
  # applicationTitle: The title displayed in the browser tab and potentially the header.
  applicationTitle: "Cloud.gov Logs"
  # useExpandedHeader: If true, uses a larger, more prominent header style.
  useExpandedHeader: false

# ==============================================================================
# 4. OpenSearch Authentication (Dashboards <-> OpenSearch)
#    Credentials and SSL settings for OpenSearch Dashboards to authenticate
#    itself to the OpenSearch cluster for internal operations (e.g., managing
#    the .opensearch_dashboards index). User authentication is handled separately.
# ==============================================================================

<% if_p('opensearch_dashboards.username') do %>
# opensearch.username: Username for OpenSearch Dashboards to authenticate with OpenSearch.
# This is used by the Dashboards server to perform maintenance on its index at startup.
# Your end-users will still need to authenticate via the configured user authentication method.
opensearch.username: <%= p('opensearch_dashboards.username') %>
<% end %>

<% if_p('opensearch_dashboards.password') do %>
# opensearch.password: Password for OpenSearch Dashboards to authenticate with OpenSearch.
opensearch.password: <%= p('opensearch_dashboards.password') %>
<% end %>

# ------------------------------------------------------------------------------
# 4.1 OpenSearch Client SSL Configuration (Dashboards <-> OpenSearch)
# These settings provide client certificates for OpenSearch Dashboards to authenticate
# to OpenSearch, particularly when client authentication is required by OpenSearch.
# ------------------------------------------------------------------------------

<% if_p('opensearch_dashboards.opensearch.ssl.certificate') do %>
# opensearch.ssl.certificate: Path to the PEM-format SSL client certificate file.
# Required if `xpack.security.http.ssl.client_authentication` in OpenSearch is set to 'required'.
opensearch.ssl.certificate: /var/vcap/jobs/opensearch_dashboards/config/ssl/dashboard-opensearch.crt
<% end %>

<% if_p('opensearch_dashboards.opensearch.ssl.private_key') do %>
# opensearch.ssl.key: Path to the PEM-format SSL private key file for the client certificate.
opensearch.ssl.key: /var/vcap/jobs/opensearch_dashboards/config/ssl/dashboard-opensearch.key
<% end %>

<% if_link("opensearch") do |opensearch_config| %>
  <% opensearch_config.if_p('opensearch.node.ssl.ca') do %>
# opensearch.ssl.certificateAuthorities: Optional path(s) to PEM file(s) for the CA
# that signed the OpenSearch instance's SSL certificate. Used to verify the identity
# of the OpenSearch cluster.
opensearch.ssl.certificateAuthorities: [ "/var/vcap/jobs/opensearch_dashboards/config/ssl/opensearch.ca" ]
  <% end %>
<% end %>

# opensearch.ssl.verificationMode: Controls SSL certificate verification for the OpenSearch connection.
# Valid values: 'full' (default, verifies hostname), 'certificate' (verifies certificate chain), 'none' (disables verification).
opensearch.ssl.verificationMode: <%= p('opensearch_dashboards.opensearch.ssl.verification_mode') %>

# ==============================================================================
# 5. Request Timeouts
#    Settings for how OpenSearch Dashboards waits for responses.
# ==============================================================================

# opensearch.requestTimeout: Time in milliseconds to wait for responses from the OpenSearch cluster.
# This must be > 0.
opensearch.requestTimeout: <%= p('opensearch_dashboards.request_timeout') %>

# opensearch.shardTimeout: Time in milliseconds for OpenSearch to wait for responses from shards.
# Set to 0 to disable.
opensearch.shardTimeout: <%= p('opensearch_dashboards.shard_timeout') %>

# ==============================================================================
# 6. User Authentication and Authorization
#    Configures how users authenticate to Dashboards and how their roles/permissions
#    are passed to OpenSearch Security.
#
#    IMPORTANT: OpenID Connect (OIDC) and Proxy Authentication are mutually exclusive.
#    Only one of these authentication methods should be enabled at a time.
# ==============================================================================

<% if p('opensearch_dashboards.oidc.enabled') %>
  <% if_link("opensearch") do |opensearch_config| %>
# ------------------------------------------------------------------------------
# 6.1 OpenID Connect (OIDC) Authentication
# Configures OpenSearch Dashboards to use OpenID Connect for user authentication.
# This method is mutually exclusive with proxy authentication.
# ------------------------------------------------------------------------------
opensearch_security.auth.type: "openid"
    <% opensearch_config.if_p('opensearch.oidc.openid_connect_url') do %>
# opensearch_security.openid.connect_url: The URL of the OpenID Connect provider's discovery endpoint.
opensearch_security.openid.connect_url: <%= opensearch_config.p('opensearch.oidc.openid_connect_url') %>
    <% end %>
    <% opensearch_config.if_p('opensearch.oidc.client_id') do %>
# opensearch_security.openid.client_id: The ID of the OpenID Connect client registered with your IdP.
opensearch_security.openid.client_id: <%= opensearch_config.p('opensearch.oidc.client_id') %>
    <% end %>
    <% opensearch_config.if_p('opensearch.oidc.client_secret') do %>
# opensearch_security.openid.client_secret: The client secret for the OpenID Connect client.
opensearch_security.openid.client_secret: <%= opensearch_config.p('opensearch.oidc.client_secret') %>
    <% end %>
    <% opensearch_config.if_p('opensearch.oidc.redirect_url') do %>
# opensearch_security.openid.base_redirect_url: The base redirect URL for OpenID Connect.
opensearch_security.openid.base_redirect_url: <%= opensearch_config.p('opensearch.oidc.redirect_url') %>
    <% end %>
# opensearch_security.openid.scope: The OpenID Connect scopes requested from the IdP.
opensearch_security.openid.scope: "all"
  <% end %>
<% end %>

<% if p('opensearch_dashboards.opensearch.enable_proxy_auth') %>
# ------------------------------------------------------------------------------
# 6.2 Advanced Proxy Authentication
# Configures OpenSearch Dashboards for proxy authentication with a different set
# of allowed headers and explicitly sets the authentication type to 'proxy'.
# This method is mutually exclusive with OpenID Connect (OIDC) authentication.
# ------------------------------------------------------------------------------
opensearch.requestHeadersAllowlist: ["securitytenant","Authorization","x-forwarded-for","x-proxy-user","x-proxy-roles","x-proxy-ext-spaceids","x-proxy-ext-orgids"]
opensearch_security.auth.type: "proxy"
opensearch_security.proxycache.user_header: "x-proxy-user"
opensearch_security.proxycache.roles_header: "x-proxy-roles"
<% end %>

# ==============================================================================
# 7. Multitenancy Configuration
#    Settings for enabling and configuring multitenancy in OpenSearch Dashboards.
# ==============================================================================
<% if p('opensearch_dashboards.multitenancy.enabled') %>
opensearch_security.multitenancy.enabled: <%= p('opensearch_dashboards.multitenancy.enabled') %>
opensearch_security.multitenancy.tenants.enable_global: <%= p('opensearch_dashboards.multitenancy.tenants.enable_global') %>
opensearch_security.multitenancy.tenants.enable_private: <%= p('opensearch_dashboards.multitenancy.tenants.enable_private') %>
opensearch_security.multitenancy.enable_filter: <%= p('opensearch_dashboards.multitenancy.enable_filter') %>
<% end %>

# ==============================================================================
# 8. Custom Configuration Options
#    Allows for injecting arbitrary key-value pairs from the BOSH manifest
#    directly into the OpenSearch Dashboards configuration.
# ==============================================================================
<% if_p('opensearch_dashboards.config_options') do p("opensearch_dashboards.config_options", {}).each do | k, v | %>
# Custom option: <%= k %>
<%= k %>: <%= v %><% end %>
<% end %>