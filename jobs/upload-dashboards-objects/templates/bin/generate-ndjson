#!/var/vcap/packages/python3-requests/venv/bin/python3
import os
import json

<% if_link("opensearch") do |opensearch| %>
folders = []
<% if opensearch.p('opensearch.deployment_type').include?('app') %>
folders.extend([
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/app/index-pattern",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/app/search",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/app/visualization",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/app/dashboard"
])
<% end %>
<% if opensearch.p('opensearch.deployment_type').include?('metric') %>
folders.extend([
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/metric/index-pattern",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/metric/search",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/metric/visualization",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/metric/dashboard"
])
<% end %>
<% if opensearch.p('opensearch.deployment_type').include?('platform') %>
folders.extend([
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/platform/index-pattern",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/platform/search",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/platform/visualization",
"/var/vcap/jobs/upload-dashboards-objects/dashboards-objects/platform/dashboard"
])
<% end %>
<% end %>



output_file = "/var/vcap/jobs/upload-dashboards-objects/dashboard.ndjson"


with open(output_file, 'w', encoding='utf-8') as output:
  for folder in folders:
    if not os.path.exists(folder):
      print(f"Folder not found: {folder}")
      continue
    for files in os.listdir(folder):
      if files.endswith(".json"):
        filepath = os.path.join(folder,files)

        with open(filepath, 'r') as json_file:
          try:
            data = json.load(json_file)
          except json.JSONDecodeError as e:
            print(f"Error with file {files}: {e}")
            continue

          json.dump(data,output)
          output.write("\n")


