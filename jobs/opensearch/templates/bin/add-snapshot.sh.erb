#!/bin/bash
# OpenSearch S3 Snapshot Repository and SM Policy Creation Script

<% if_p('opensearch.repository.s3.region', 'opensearch.repository.s3.bucket', 'opensearch.repository.s3.name', 'opensearch.repository.s3.access_key', 'opensearch.repository.s3.secret_key', 'opensearch.repository.s3.path') do |region, bucket, repo_name, access_key, secret_key, s3_path| %>
set -e

export JOB_NAME=opensearch
export JOB_DIR=/var/vcap/jobs/$JOB_NAME

OPENSEARCH_URL="https://localhost:9200"
REPOSITORY_NAME="<%= repo_name %>"
S3_BUCKET="<%= bucket %>"
S3_PATH="<%= s3_path %>"
AWS_REGION="<%= region %>"

# SSL Certificate options
CA="--cacert ${JOB_DIR}/config/ssl/opensearch.ca"
CERT="--cert ${JOB_DIR}/config/ssl/opensearch-admin.crt"
KEY="--key ${JOB_DIR}/config/ssl/opensearch-admin.key"

echo "=== Creating OpenSearch S3 Snapshot Repository ==="

# Reload secure settings to pick up keystore changes from all nodes
echo "Reloading secure settings..."
curl -s -X POST "${OPENSEARCH_URL}/_nodes/reload_secure_settings" \
  ${CA} ${CERT} ${KEY} \
  -H "Content-Type: application/json" \
  -d '{}'

sleep 5

# Create the repository
echo "Creating repository..."
RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/create_repo_response.json \
  -X PUT "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}" \
  ${CA} ${CERT} ${KEY} \
  -H "Content-Type: application/json" \
  -d '{
    "type": "s3",
    "settings": {
      "bucket": "'$S3_BUCKET'",
      "base_path": "'$S3_PATH'",
      "region": "'$AWS_REGION'",
      "compress": true,
      "server_side_encryption": true,
      "storage_class": "standard"
    }
  }')

if [ "$RESPONSE" = "200" ]; then
    echo "Repository created successfully"
    cat /tmp/create_repo_response.json
else
    echo "Failed to create repository (HTTP $RESPONSE)"
    cat /tmp/create_repo_response.json
    exit 1
fi

echo ""
echo "=== Verifying Repository ==="

VERIFY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/verify_repo_response.json \
  -X GET "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}?pretty" \
  ${CA} ${CERT} ${KEY})

if [ "$VERIFY_RESPONSE" = "200" ]; then
    echo "Repository verification successful"
    cat /tmp/verify_repo_response.json
else
    echo "Repository verification failed (HTTP $VERIFY_RESPONSE)"
    cat /tmp/verify_repo_response.json
fi

echo ""
echo "=== Testing Repository Connection ==="

TEST_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/test_repo_response.json \
  -X POST "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}/_verify?pretty" \
  ${CA} ${CERT} ${KEY})

if [ "$TEST_RESPONSE" = "200" ]; then
    echo "Repository connection test successful"
    cat /tmp/test_repo_response.json
else
    echo "Repository connection test failed (HTTP $TEST_RESPONSE)"
    cat /tmp/test_repo_response.json
fi

echo ""
echo "=== Creating Snapshot Management (SM) Policies ==="

# Create SM Policy for logs-app (1 year / 365 days retention)
echo "Creating SM policy for logs-app* indices (365 day retention)..."
LOGS_APP_POLICY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/sm_policy_app_response.json \
  -X POST "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-app-snapshot-policy" \
  ${CA} ${CERT} ${KEY} \
  -H "Content-Type: application/json" \
  -d '{
    "description": "Daily snapshots of logs-app indices with 1 year retention",
    "creation": {
      "schedule": {
        "cron": {
          "expression": "0 0 * * *",
          "timezone": "UTC"
        }
      },
      "time_limit": "1h"
    },
    "deletion": {
      "schedule": {
        "cron": {
          "expression": "0 1 * * *",
          "timezone": "UTC"
        }
      },
      "condition": {
        "max_age": "365d",
        "max_count": 400,
        "min_count": 1
      },
      "time_limit": "1h"
    },
    "snapshot_config": {
      "repository": "'${REPOSITORY_NAME}'",
      "indices": "logs-app*",
      "ignore_unavailable": true,
      "include_global_state": false,
      "partial": true
    },
    "notification": {
      "channel": {
        "id": ""
      },
      "conditions": {
        "creation": true,
        "deletion": true,
        "failure": true
      }
    },
    "enabled": true
  }')

if [ "$LOGS_APP_POLICY_RESPONSE" = "200" ] || [ "$LOGS_APP_POLICY_RESPONSE" = "201" ]; then
    echo "SM policy for logs-app created successfully"
    cat /tmp/sm_policy_app_response.json
else
    echo "Failed to create SM policy for logs-app (HTTP $LOGS_APP_POLICY_RESPONSE)"
    cat /tmp/sm_policy_app_response.json
fi

echo ""

# Create SM Policy for logs-metric (90 days retention)
echo "Creating SM policy for logs-metric* indices (90 day retention)..."
LOGS_METRIC_POLICY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/sm_policy_metric_response.json \
  -X POST "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-metric-snapshot-policy" \
  ${CA} ${CERT} ${KEY} \
  -H "Content-Type: application/json" \
  -d '{
    "description": "Daily snapshots of logs-metric indices with 90 day retention",
    "creation": {
      "schedule": {
        "cron": {
          "expression": "0 0 * * *",
          "timezone": "UTC"
        }
      },
      "time_limit": "1h"
    },
    "deletion": {
      "schedule": {
        "cron": {
          "expression": "0 1 * * *",
          "timezone": "UTC"
        }
      },
      "condition": {
        "max_age": "90d",
        "max_count": 100,
        "min_count": 1
      },
      "time_limit": "1h"
    },
    "snapshot_config": {
      "repository": "'${REPOSITORY_NAME}'",
      "indices": "logs-metric*",
      "ignore_unavailable": true,
      "include_global_state": false,
      "partial": true
    },
    "notification": {
      "channel": {
        "id": ""
      },
      "conditions": {
        "creation": true,
        "deletion": true,
        "failure": true
      }
    },
    "enabled": true
  }')

if [ "$LOGS_METRIC_POLICY_RESPONSE" = "200" ] || [ "$LOGS_METRIC_POLICY_RESPONSE" = "201" ]; then
    echo "SM policy for logs-metric created successfully"
    cat /tmp/sm_policy_metric_response.json
else
    echo "Failed to create SM policy for logs-metric (HTTP $LOGS_METRIC_POLICY_RESPONSE)"
    cat /tmp/sm_policy_metric_response.json
fi

echo ""
echo "=== Listing All SM Policies ==="

LIST_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/sm_list_response.json \
  -X GET "${OPENSEARCH_URL}/_plugins/_sm/policies?pretty" \
  ${CA} ${CERT} ${KEY})

if [ "$LIST_RESPONSE" = "200" ]; then
    echo "SM policies listing:"
    cat /tmp/sm_list_response.json
else
    echo "Failed to list SM policies (HTTP $LIST_RESPONSE)"
    cat /tmp/sm_list_response.json
fi

# Cleanup temp files
rm -f /tmp/create_repo_response.json /tmp/verify_repo_response.json /tmp/test_repo_response.json
rm -f /tmp/sm_policy_app_response.json /tmp/sm_policy_metric_response.json /tmp/sm_list_response.json

echo ""
echo "=== Snapshot Repository and SM Policy Setup Complete ==="
echo ""
echo "Summary:"
echo "  - Repository: ${REPOSITORY_NAME}"
echo "  - logs-app* snapshots: Daily at 00:00 UTC, retained for 365 days"
echo "  - logs-metric* snapshots: Daily at 00:00 UTC, retained for 90 days"

<% end %>
