#!/bin/bash
# OpenSearch S3 Snapshot Repository and SM Policy Creation Script

<% if p('opensearch.repository.s3.enabled') %>
<% if_p('opensearch.repository.s3.region', 'opensearch.repository.s3.bucket', 'opensearch.repository.s3.name', 'opensearch.repository.s3.path') do |region, bucket, repo_name, s3_path| %>
set -e

export JOB_NAME=opensearch
export JOB_DIR=/var/vcap/jobs/$JOB_NAME

OPENSEARCH_URL="https://localhost:9200"
REPOSITORY_NAME="<%= repo_name %>"
S3_BUCKET="<%= bucket %>"
S3_PATH="<%= s3_path %>"
AWS_REGION="<%= region %>"

# SSL Certificate options
CA="--cacert ${JOB_DIR}/config/ssl/opensearch.ca"
CERT="--cert ${JOB_DIR}/config/ssl/opensearch-admin.crt"
KEY="--key ${JOB_DIR}/config/ssl/opensearch-admin.key"

echo "=== Creating OpenSearch S3 Snapshot Repository ==="

# Wait for cluster to be green/yellow before proceeding
echo "Waiting for cluster health..."
for i in {1..30}; do
    HEALTH=$(curl -s ${CA} ${CERT} ${KEY} "${OPENSEARCH_URL}/_cluster/health" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
    if [ "$HEALTH" = "green" ] || [ "$HEALTH" = "yellow" ]; then
        echo "Cluster health: $HEALTH"
        break
    fi
    echo "Waiting for cluster health (attempt $i/30, current: $HEALTH)..."
    sleep 5
done

echo "Reloading secure settings on all nodes..."
RELOAD_RESPONSE=$(curl -s -X POST "${OPENSEARCH_URL}/_nodes/reload_secure_settings" \
  ${CA} ${CERT} ${KEY} \
  -H "Content-Type: application/json" \
  -d '{}')

sleep 10

# Check if repository already exists
EXISTING_REPO=$(curl -s -w "%{http_code}" -o /tmp/check_repo_response.json \
  -X GET "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}" \
  ${CA} ${CERT} ${KEY})

if [ "$EXISTING_REPO" = "200" ]; then
    echo "Repository ${REPOSITORY_NAME} already exists"
    cat /tmp/check_repo_response.json
else
    # Create the repository
    echo "Creating repository..."
    RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/create_repo_response.json \
      -X PUT "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}" \
      ${CA} ${CERT} ${KEY} \
      -H "Content-Type: application/json" \
      -d '{
        "type": "s3",
        "settings": {
          "bucket": "'$S3_BUCKET'",
          "base_path": "'$S3_PATH'",
          "compress": true
        }
      }')

    if [ "$RESPONSE" = "200" ]; then
        echo "Repository created successfully"
        cat /tmp/create_repo_response.json
    else
        echo "Failed to create repository (HTTP $RESPONSE)"
        cat /tmp/create_repo_response.json
        exit 1
    fi
fi

for i in {1..12}; do
    VERIFY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/verify_repo_response.json \
      -X POST "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}/_verify" \
      ${CA} ${CERT} ${KEY})
    
    if [ "$VERIFY_RESPONSE" = "200" ]; then
        echo "Repository verified on all nodes"
        break
    fi
    
    echo "Waiting for repository verification (attempt $i/12)..."
    sleep 5
done

VERIFY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/verify_repo_response.json \
  -X GET "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}?pretty" \
  ${CA} ${CERT} ${KEY})

if [ "$VERIFY_RESPONSE" = "200" ]; then
    echo "Repository verification successful"
    cat /tmp/verify_repo_response.json
else
    echo "Repository verification failed (HTTP $VERIFY_RESPONSE)"
    cat /tmp/verify_repo_response.json
fi

echo ""
echo "=== Testing Repository Connection ==="

TEST_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/test_repo_response.json \
  -X POST "${OPENSEARCH_URL}/_snapshot/${REPOSITORY_NAME}/_verify?pretty" \
  ${CA} ${CERT} ${KEY})

if [ "$TEST_RESPONSE" = "200" ]; then
    echo "Repository connection test successful"
    cat /tmp/test_repo_response.json
else
    echo "Repository connection test failed (HTTP $TEST_RESPONSE)"
    cat /tmp/test_repo_response.json
fi

echo ""
echo "=== Creating Snapshot Management (SM) Policies ==="

<% if p('opensearch.deployment_type').include?('platform') %>
# Platform deployment: Create logs-platform* policy with 186 day snapshot retention
EXISTING_PLATFORM_POLICY=$(curl -s -w "%{http_code}" -o /tmp/check_platform_policy.json \
  -X GET "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-platform-snapshot-policy" \
  ${CA} ${CERT} ${KEY})

if [ "$EXISTING_PLATFORM_POLICY" = "200" ]; then
    echo "SM policy for logs-platform already exists"
else
    # 183 days active in OpenSearch + 186 daily snapshots = ~369 days total coverage (1 year+)
    echo "Creating SM policy for logs-platform* indices (186 snapshot retention)..."
    LOGS_PLATFORM_POLICY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/sm_policy_platform_response.json \
      -X POST "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-platform-snapshot-policy" \
      ${CA} ${CERT} ${KEY} \
      -H "Content-Type: application/json" \
      -d '{
        "description": "Daily snapshots of logs-platform indices with 186 snapshot retention",
        "creation": {
          "schedule": {
            "cron": {
              "expression": "0 0 * * *",
              "timezone": "UTC"
            }
          },
          "time_limit": "1h"
        },
        "deletion": {
          "schedule": {
            "cron": {
              "expression": "0 1 * * *",
              "timezone": "UTC"
            }
          },
          "condition": {
            "max_count": 186,
            "min_count": 1
          },
          "time_limit": "1h"
        },
        "snapshot_config": {
          "repository": "'${REPOSITORY_NAME}'",
          "indices": "logs-platform*",
          "ignore_unavailable": true,
          "include_global_state": false,
          "partial": true
        },
        "enabled": true
      }')

    if [ "$LOGS_PLATFORM_POLICY_RESPONSE" = "200" ] || [ "$LOGS_PLATFORM_POLICY_RESPONSE" = "201" ]; then
        echo "SM policy for logs-platform created successfully"
        cat /tmp/sm_policy_platform_response.json
    else
        echo "Failed to create SM policy for logs-platform (HTTP $LOGS_PLATFORM_POLICY_RESPONSE)"
        cat /tmp/sm_policy_platform_response.json
    fi
fi
<% else %>
# Non-platform deployment: Create logs-app* and logs-metric* policies
EXISTING_APP_POLICY=$(curl -s -w "%{http_code}" -o /tmp/check_app_policy.json \
  -X GET "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-app-snapshot-policy" \
  ${CA} ${CERT} ${KEY})

if [ "$EXISTING_APP_POLICY" = "200" ]; then
    echo "SM policy for logs-app already exists"
else
    # 183 days active in OpenSearch + 186 daily snapshots = ~369 days total coverage (1 year+)
    echo "Creating SM policy for logs-app* indices (186 snapshot retention)..."
    LOGS_APP_POLICY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/sm_policy_app_response.json \
      -X POST "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-app-snapshot-policy" \
      ${CA} ${CERT} ${KEY} \
      -H "Content-Type: application/json" \
      -d '{
        "description": "Daily snapshots of logs-app indices with 186 snapshot retention",
        "creation": {
          "schedule": {
            "cron": {
              "expression": "0 0 * * *",
              "timezone": "UTC"
            }
          },
          "time_limit": "1h"
        },
        "deletion": {
          "schedule": {
            "cron": {
              "expression": "0 1 * * *",
              "timezone": "UTC"
            }
          },
          "condition": {
            "max_count": 186,
            "min_count": 1
          },
          "time_limit": "1h"
        },
        "snapshot_config": {
          "repository": "'${REPOSITORY_NAME}'",
          "indices": "logs-app*",
          "ignore_unavailable": true,
          "include_global_state": false,
          "partial": true
        },
        "enabled": true
      }')

    if [ "$LOGS_APP_POLICY_RESPONSE" = "200" ] || [ "$LOGS_APP_POLICY_RESPONSE" = "201" ]; then
        echo "SM policy for logs-app created successfully"
        cat /tmp/sm_policy_app_response.json
    else
        echo "Failed to create SM policy for logs-app (HTTP $LOGS_APP_POLICY_RESPONSE)"
        cat /tmp/sm_policy_app_response.json
    fi
fi


EXISTING_METRIC_POLICY=$(curl -s -w "%{http_code}" -o /tmp/check_metric_policy.json \
  -X GET "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-metric-snapshot-policy" \
  ${CA} ${CERT} ${KEY})

if [ "$EXISTING_METRIC_POLICY" = "200" ]; then
    echo "SM policy for logs-metric already exists"
else
    # Keep only 4 snapshots for metrics - minimal retention needed
    echo "Creating SM policy for logs-metric* indices (4 snapshot retention)..."
    LOGS_METRIC_POLICY_RESPONSE=$(curl -s -w "%{http_code}" -o /tmp/sm_policy_metric_response.json \
      -X POST "${OPENSEARCH_URL}/_plugins/_sm/policies/logs-metric-snapshot-policy" \
      ${CA} ${CERT} ${KEY} \
      -H "Content-Type: application/json" \
      -d '{
        "description": "Daily snapshots of logs-metric indices with 4 snapshot retention",
        "creation": {
          "schedule": {
            "cron": {
              "expression": "0 0 * * *",
              "timezone": "UTC"
            }
          },
          "time_limit": "1h"
        },
        "deletion": {
          "schedule": {
            "cron": {
              "expression": "0 1 * * *",
              "timezone": "UTC"
            }
          },
          "condition": {
            "max_count": 4,
            "min_count": 1
          },
          "time_limit": "1h"
        },
        "snapshot_config": {
          "repository": "'${REPOSITORY_NAME}'",
          "indices": "logs-metric*",
          "ignore_unavailable": true,
          "include_global_state": false,
          "partial": true
        },
        "enabled": true
      }')

    if [ "$LOGS_METRIC_POLICY_RESPONSE" = "200" ] || [ "$LOGS_METRIC_POLICY_RESPONSE" = "201" ]; then
        echo "SM policy for logs-metric created successfully"
        cat /tmp/sm_policy_metric_response.json
    else
        echo "Failed to create SM policy for logs-metric (HTTP $LOGS_METRIC_POLICY_RESPONSE)"
        cat /tmp/sm_policy_metric_response.json
    fi
fi
<% end %>


# Cleanup temp files
rm -f /tmp/create_repo_response.json /tmp/check_repo_response.json /tmp/verify_repo_response.json /tmp/test_repo_response.json
rm -f /tmp/sm_policy_app_response.json /tmp/sm_policy_metric_response.json /tmp/sm_policy_platform_response.json /tmp/sm_list_response.json
rm -f /tmp/check_app_policy.json /tmp/check_metric_policy.json /tmp/check_platform_policy.json

<% end %>
<% end %>
