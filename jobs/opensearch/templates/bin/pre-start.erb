#!/usr/bin/env bash
export JOB_NAME=opensearch
export OPENSEARCH_HOME=/var/vcap/packages/opensearch
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config
export OPENSEARCH_SECURITY_CONFIG_PATH=${OPENSEARCH_PATH_CONF}/opensearch-security
export OPENSEARCH_JAVA_OPTS="-XX:-UsePerfData -Dnet.bytebuddy.agent.disabled=true -Djava.io.tmpdir=/var/vcap/data/opensearch/"
export YQ_PACKAGE_DIR=/var/vcap/packages/yq
export PATH=$YQ_PACKAGE_DIR/bin:$PATH
export PATH=/var/vcap/packages/cf-cli-8-linux/bin:$PATH
export KEYSTORE="/var/vcap/packages/openjdk-21/lib/security/cacerts"
STOREPASS=<%= p("opensearch.notification.keystorepass") %>
DEFAULTPASS=<%= p("opensearch.notification.defaultkeystorepass") %>

################################################################
# FIPS Configuration
################################################################
<% if p("opensearch.fips.enabled", false) %>
echo "Configuring OpenSearch for FIPS mode..."

# Check if FIPS JAR is available
FIPS_JAR_PATH="/var/vcap/packages/openjdk-21/lib/bc-fips-2.1.2.jar"
if ! ls "$FIPS_JAR_PATH" 1> /dev/null 2>&1; then
    echo "ERROR: FIPS enabled but FIPS JAR not found at $FIPS_JAR_PATH"
    exit 1
fi

# Create directories and copy FIPS JAR early
mkdir -p /var/vcap/data/opensearch
FIPS_LIB_DIR="/var/vcap/data/opensearch/fips-lib"
mkdir -p "${FIPS_LIB_DIR}"
JDK_LIB="/var/vcap/packages/openjdk-21/lib"


echo "Removing conflicting BouncyCastle JARs from OpenSearch..."
for j in $(find /var/vcap/packages/opensearch -name '*bouncycastle*.jar' -o -name '*bcprov*.jar' -o -name '*bcpkix*.jar'); do
  echo "Removing conflicting JAR: $j"
  rm -f "$j"
done

# Also check for BC JARs that might conflict
find /var/vcap/packages/opensearch -name '*.jar' -exec sh -c '
  if unzip -l "$1" 2>/dev/null | grep -q "org/bouncycastle" && ! echo "$1" | grep -q fips; then
    echo "Found non-FIPS BC content in: $1"
  fi
' _ {} \;

FIPS_CP=""
for jar in bc-fips bctls-fips bcutil-fips; do
    src=$(ls ${JDK_LIB}/${jar}-*.jar 2>/dev/null | head -n1)
    if [ -z "$src" ] || [ ! -f "$src" ]; then
       echo "ERROR: FIPS enabled but ${jar}-*.jar not found in ${JDK_LIB}"
       exit 1
    fi
    cp "$src" "${FIPS_LIB_DIR}/"
    cp "$src" "${OPENSEARCH_HOME}/lib/"
    FIPS_CP="${FIPS_CP}:${FIPS_LIB_DIR}/$(basename "$src")"
done 

for j in $(find /var/vcap/packages/opensearch -name '*.jar'); do 
  if unzip -l "$j" 2>/dev/null | grep -q 'org/bouncycastle/asn1/ASN1Integer.class'; then
    echo "$j"
    fi
done
FIPS_CP="${FIPS_CP#:}"

# Create FIPS security properties file
mkdir -p "${OPENSEARCH_PATH_CONF}"
cat > "${OPENSEARCH_PATH_CONF}/fips.security" << EOF
# FIPS Security Configuration with SSL Context Support
security.provider.1=org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider C:HYBRID;ENABLE{All};
security.provider.2=sun.security.provider.Sun 
security.provider.3=org.bouncycastle.jsse.provider.BouncyCastleJsseProvider fips:BCFIPS
security.provider.4=sun.security.rsa.SunRsaSign
security.provider.5=sun.security.ec.SunEC

# SSL/TLS Configuration for Security Plugin Compatibility
ssl.TrustManagerFactory.algorithm=PKIX
ssl.KeyManagerFactory.algorithm=X509
keystore.type=BCFKS

# Protocol support
jdk.tls.client.protocols=TLSv1.2,TLSv1.3
jdk.tls.server.protocols=TLSv1.2,TLSv1.3

# Disable weak algorithms
jdk.tls.disabledAlgorithms=SSLv2Hello, SSLv3, TLSv1, TLSv1.1, RC4, DES, MD5withRSA, DH keySize < 2048, EC keySize < 224, 3DES_EDE_CBC, anon, NULL
jdk.certpath.disabledAlgorithms=MD2, MD5, RSA keySize < 2048, DSA keySize < 2048, EC keySize < 224
EOF

# Set FIPS keystore password
export OPENSEARCH_KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"

# Add FIPS JVM options immediately
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -cp ${FIPS_CP}"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Dorg.bouncycastle.fips.approved_only=<%= p('opensearch.fips.strict', true) %>"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djava.security.properties=${OPENSEARCH_PATH_CONF}/fips.security"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djavax.net.ssl.keyStoreType=BCFKS"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djavax.net.ssl.trustStoreType=BCFKS"

# Create wrapper function for FIPS-enabled keytool
fips_keytool() {
    /var/vcap/packages/openjdk-21/bin/keytool \
        -J-cp -J"${FIPS_CP}" \
        -J-Djava.io.tmpdir=/var/vcap/data/opensearch/ \
        -J-Djava.security.properties="${OPENSEARCH_PATH_CONF}/fips.security" \
        "$@"
}

export OPENSEARCH_FIPS_MODE=true
echo "FIPS mode enabled"
<% else %>
echo "FIPS mode disabled - using standard configuration"
export OPENSEARCH_FIPS_MODE=false
<% end %>

################################################################
# Existing keystore password change
################################################################
/var/vcap/packages/openjdk-21/bin/keytool -storepasswd -new $STOREPASS -cacerts -storepass "$DEFAULTPASS" > /dev/null 2>&1;

sysctl -q -w vm.max_map_count=262144
mkdir -p ${OPENSEARCH_HOME}/plugins

if [ -d ${JOB_DIR}/config/ssl ]; then
    chown vcap ${JOB_DIR}/config/ssl
fi

source /var/vcap/packages/openjdk-21/bosh/runtime.env

# Copy default security config if it doesn't already exist
# Have to copy files that don't exist otherwise securityadmin.sh invocation will fail
cp -u ${OPENSEARCH_HOME}/config/opensearch-security/*.yml "$OPENSEARCH_SECURITY_CONFIG_PATH"

cd ${OPENSEARCH_HOME}
chown -R vcap:vcap config plugins
chown -R vcap:vcap "$OPENSEARCH_SECURITY_CONFIG_PATH"

<% if_p('opensearch.cf.domain', 'opensearch.cf.client_id', 'opensearch.cf.client_password') do %>
<% if p("opensearch.node.allow_data") %>
<%
  api = p("opensearch.cf.domain")
  client = p("opensearch.cf.client_id")
  password = p("opensearch.cf.client_password")
%>
cf api "<%= api %>"
cf auth "<%= client %>" "<%= password %>" --client-credentials

# Prepare tenants, roles, and role mappings so that they don't get overridden by securityadmin.sh
# script invocation in post-start
ORG_GUID_LIST=()
for org in $(cf orgs | tail -n +4); do
  ORG_GUID=$(cf org "$org" --guid)
  ROLE_NAME="$org-tenant"
  ORG_GUID_LIST+=("\"$ORG_GUID\"")
  yq -i ".\"$org\"={\"description\":\"tenant for $org\"}" "$OPENSEARCH_SECURITY_CONFIG_PATH/tenants.yml"
  yq -i ".\"$ROLE_NAME\"={\"tenant_permissions\":[{\"tenant_patterns\":[\"$org\"],\"allowed_actions\":[\"kibana_all_write\"]}]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles.yml"
  yq -i ".\"$ROLE_NAME\"={\"backend_roles\": [\"$ORG_GUID\"]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
done

# this makes a list of cf org guids and assigns them to roles, making users with a org have access to the following roles.
ORG_GUID_ROLE_LIST=$(IFS=,; echo "${ORG_GUID_LIST[*]}")
yq -i ".cf_user={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".reports_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".alerting_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".notifications_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
<% end %>
<% end %>

# Plugin installations
<% if_p('opensearch.repository.s3.access_key', 'opensearch.repository.s3.secret_key') do %>
  ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b repository-s3
  echo '<%= p('opensearch.repository.s3.access_key') %>' \
    | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin s3.client.default.access_key
  echo '<%= p('opensearch.repository.s3.secret_key') %>' \
    | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin s3.client.default.secret_key
<% end %>

<% p("opensearch.plugins").each do |plugin| name, path = plugin.first %>
  <% if path.start_with? '/var/vcap' %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "file://<%= path %>"
  <% elsif path.start_with? 'http' %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "<%= path %>"
  <% else %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "<%= path %>"
  <% end %>
<% end %>

#requested
${OPENSEARCH_HOME}/bin/opensearch-plugin install -b workload-management 

log_dir=${OPENSEARCH_HOME}/logs
if [[ ! -a ${log_dir} ]]; then
  ln -s /var/vcap/sys/log/opensearch ${log_dir}
fi

<% if p("opensearch.fips.enabled", false) %>
# Set minimum 6-character password for FIPS mode
export OPENSEARCH_KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"
<% end %>

# Create new OpenSearch keystore
if [ ! -f "$OPENSEARCH_PATH_CONF/opensearch.keystore" ]; then
  echo "Create new OpenSearch keystore"
<% if p("opensearch.fips.enabled", false) %>
  echo "Creating FIPS-compliant password-protected keystore..."
  {
    echo "${OPENSEARCH_KEYSTORE_PASSWORD}"
    echo "${OPENSEARCH_KEYSTORE_PASSWORD}"
  } | "$PACKAGE_DIR/bin/opensearch-keystore" create --password
<% else %>
  # Non-FIPS mode
  echo y | "$PACKAGE_DIR/bin/opensearch-keystore" create
<% end %>
fi

if [ -f "$OPENSEARCH_PATH_CONF/opensearch.keystore" ]; then
  chown vcap:vcap "$OPENSEARCH_PATH_CONF/opensearch.keystore"
  chmod 600 "$OPENSEARCH_PATH_CONF/opensearch.keystore"
else
  echo "ERROR: Failed to create OpenSearch keystore"
  exit 1
fi

################################################################
# FIPS Keystore Setup 
################################################################
<% if p("opensearch.fips.enabled", false) %>
echo "Setting up FIPS keystores..."

# FIPS keystore/truststore setup
FIPS_KEYSTORE_PATH="/var/vcap/data/opensearch/keystore.bcfks"
FIPS_TRUSTSTORE_PATH="/var/vcap/data/opensearch/truststore.bcfks"
FIPS_STORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"

# Validate password length
if [ ${#FIPS_STORE_PASSWORD} -lt 14 ]; then
    echo "ERROR: FIPS keystore password must be at least 14 characters long"
    exit 1
fi

echo "Testing FIPS keytool functionality..."

# Test 1: Check if keytool can access FIPS providers
echo "Testing FIPS provider availability..."
if fips_keytool -help >/dev/null 2>&1; then
    echo "FIPS keytool basic functionality: OK"
else
    echo "ERROR: FIPS keytool basic functionality failed"
    exit 1
fi

# Test 2: Try to create a temporary BCFKS keystore
echo "Testing BCFKS keystore creation..."
TEST_KEYSTORE="/tmp/test-fips-keystore.bcfks"
rm -f "$TEST_KEYSTORE"

if fips_keytool -genkeypair \
    -alias test \
    -keyalg RSA \
    -keysize 2048 \
    -validity 1 \
    -keystore "$TEST_KEYSTORE" \
    -storetype BCFKS \
    -storepass "TestPassword123!" \
    -keypass "TestPassword123!" \
    -dname "CN=test,O=test,C=US" 2>/dev/null; then
    
    echo "BCFKS keystore creation test: OK"
    
    # Test 3: Verify we can list the test keystore
    if fips_keytool -list -keystore "$TEST_KEYSTORE" -storetype BCFKS -storepass "TestPassword123!" >/dev/null 2>&1; then
        echo "BCFKS keystore listing test: OK"
    else
        echo "WARNING: BCFKS keystore listing failed, but creation worked"
    fi
    
    # Clean up test keystore
    rm -f "$TEST_KEYSTORE"
else
    echo "ERROR: BCFKS keystore creation test failed"
    echo "Debug: Trying to get more information..."
    
    # Debug: Try to see what providers are available
    /var/vcap/packages/openjdk-21/bin/java \
        -Djava.security.properties="${OPENSEARCH_PATH_CONF}/fips.security" \
        -c "java.security.Security.getProviders(); java.util.Arrays.stream(java.security.Security.getProviders()).forEach(p -> System.out.println(p.getName()));" 2>/dev/null
    
    exit 1
fi

echo "All FIPS keytool tests passed"

# Continue with actual keystore creation...
# Create FIPS keystore if it doesn't exist
if [ ! -f "$FIPS_KEYSTORE_PATH" ]; then
    echo "Creating FIPS keystore..."
    fips_keytool -genkeypair \
        -alias opensearch-node \
        -keyalg RSA \
        -keysize 2048 \
        -validity 365 \
        -keystore "$FIPS_KEYSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -keypass "$FIPS_STORE_PASSWORD" \
        -dname "CN=<%= spec.address || spec.name %>, O=GSA, C=US"
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create FIPS keystore"
        exit 1
    fi
    echo "FIPS keystore created successfully"

    chown vcap:vcap "$FIPS_KEYSTORE_PATH"
    chmod 600 "$FIPS_KEYSTORE_PATH"
fi

# Create FIPS truststore if it doesn't exist  
if [ ! -f "$FIPS_TRUSTSTORE_PATH" ]; then
    echo "Creating FIPS truststore..."
    
    # Export cert from keystore
    fips_keytool -exportcert \
        -alias opensearch-node \
        -keystore "$FIPS_KEYSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file /tmp/opensearch-cert.pem
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to export certificate from keystore"
        exit 1
    fi
    
    # Import cert to truststore
    fips_keytool -importcert \
        -alias opensearch-ca \
        -keystore "$FIPS_TRUSTSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file /tmp/opensearch-cert.pem \
        -noprompt
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create FIPS truststore"
        rm -f /tmp/opensearch-cert.pem
        exit 1
    fi
    
    rm -f /tmp/opensearch-cert.pem
    echo "FIPS truststore created successfully"

    chown vcap:vcap "$FIPS_TRUSTSTORE_PATH"
    chmod 600 "$FIPS_TRUSTSTORE_PATH"
fi

<% if_p('opensearch.fips.ca_certificate') do |ca_cert| %>
# Import provided CA certificate
echo "Importing provided CA certificate..."
echo "<%= ca_cert %>" > /tmp/ca-cert.pem

fips_keytool -importcert \
    -alias provided-ca \
    -keystore "$FIPS_TRUSTSTORE_PATH" \
    -storetype BCFKS \
    -storepass "$FIPS_STORE_PASSWORD" \
    -file ${JOB_DIR}/config/ssl/opensearch.ca \
    -noprompt

if [ $? -eq 0 ]; then
    echo "CA certificate imported successfully"

    chown vcap:vcap "$FIPS_TRUSTSTORE_PATH"
    chmod 600 "$FIPS_TRUSTSTORE_PATH"
else
    echo "WARNING: Failed to import CA certificate"
fi

rm -f /tmp/ca-cert.pem
<% end %>

# Import deployment SSL certificates into FIPS keystores if provided
<% if_p('opensearch.node.ssl.certificate', 'opensearch.node.ssl.private_key', 'opensearch.node.ssl.ca') do %>
echo "Importing deployment node SSL certificates into FIPS keystore..."

# Create a temporary PKCS12 from PEM files, then import to BCFKS
NODE_CERT="${JOB_DIR}/config/ssl/opensearch-node.crt"
NODE_KEY="${JOB_DIR}/config/ssl/opensearch-node.pem"
NODE_CA="${JOB_DIR}/config/ssl/opensearch.ca"
TEMP_P12="/tmp/opensearch-node.p12"

# Convert PEM to PKCS12
openssl pkcs12 -export \
    -in "$NODE_CERT" \
    -inkey "$NODE_KEY" \
    -certfile "$NODE_CA" \
    -name "opensearch-node" \
    -out "$TEMP_P12" \
    -passout "pass:${FIPS_STORE_PASSWORD}"

if [ $? -eq 0 ]; then
    # Delete existing self-signed entry if present
    fips_keytool -delete -alias opensearch-node \
        -keystore "$FIPS_KEYSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" 2>/dev/null || true

    # Import PKCS12 into BCFKS keystore
    fips_keytool -importkeystore \
        -srckeystore "$TEMP_P12" \
        -srcstoretype PKCS12 \
        -srcstorepass "$FIPS_STORE_PASSWORD" \
        -destkeystore "$FIPS_KEYSTORE_PATH" \
        -deststoretype BCFKS \
        -deststorepass "$FIPS_STORE_PASSWORD" \
        -destkeypass "$FIPS_STORE_PASSWORD" \
        -noprompt

    if [ $? -eq 0 ]; then
        echo "Node SSL certificate imported to FIPS keystore successfully"
    else
        echo "WARNING: Failed to import node certificate to FIPS keystore"
    fi

    # Import CA cert to truststore
    fips_keytool -delete -alias opensearch-ca \
        -keystore "$FIPS_TRUSTSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" 2>/dev/null || true

    fips_keytool -importcert \
        -alias opensearch-node-ca \
        -keystore "$FIPS_TRUSTSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file "$NODE_CA" \
        -noprompt

    if [ $? -eq 0 ]; then
        echo "Node CA certificate imported to FIPS truststore successfully"
    else
        echo "WARNING: Failed to import node CA to FIPS truststore"
    fi
else
    echo "WARNING: Failed to create PKCS12 from PEM certificates"
fi

rm -f "$TEMP_P12"

chown vcap:vcap "$FIPS_KEYSTORE_PATH" "$FIPS_TRUSTSTORE_PATH" 2>/dev/null
chmod 600 "$FIPS_KEYSTORE_PATH" "$FIPS_TRUSTSTORE_PATH" 2>/dev/null
<% end %>

# Import HTTP SSL certificates if different from node certs
<% if_p('opensearch.http.ssl.certificate', 'opensearch.http.ssl.private_key') do %>
echo "Importing deployment HTTP SSL certificates into FIPS keystore..."

HTTP_CERT="${JOB_DIR}/config/ssl/opensearch-http.crt"
HTTP_KEY="${JOB_DIR}/config/ssl/opensearch-http.pem"
HTTP_CA="${JOB_DIR}/config/ssl/opensearch.ca"
TEMP_HTTP_P12="/tmp/opensearch-http.p12"

# Convert PEM to PKCS12
openssl pkcs12 -export \
    -in "$HTTP_CERT" \
    -inkey "$HTTP_KEY" \
    -certfile "$HTTP_CA" \
    -name "opensearch-http" \
    -out "$TEMP_HTTP_P12" \
    -passout "pass:${FIPS_STORE_PASSWORD}"

if [ $? -eq 0 ]; then
    # Import PKCS12 into BCFKS keystore
    fips_keytool -importkeystore \
        -srckeystore "$TEMP_HTTP_P12" \
        -srcstoretype PKCS12 \
        -srcstorepass "$FIPS_STORE_PASSWORD" \
        -destkeystore "$FIPS_KEYSTORE_PATH" \
        -deststoretype BCFKS \
        -deststorepass "$FIPS_STORE_PASSWORD" \
        -destkeypass "$FIPS_STORE_PASSWORD" \
        -noprompt

    if [ $? -eq 0 ]; then
        echo "HTTP SSL certificate imported to FIPS keystore successfully"
    else
        echo "WARNING: Failed to import HTTP certificate to FIPS keystore"
    fi
else
    echo "WARNING: Failed to create PKCS12 from HTTP PEM certificates"
fi

rm -f "$TEMP_HTTP_P12"
<% end %>

# Set proper permissions for FIPS keystores
chown vcap:vcap "$FIPS_KEYSTORE_PATH" "$FIPS_TRUSTSTORE_PATH" 2>/dev/null
chmod 600 "$FIPS_KEYSTORE_PATH" "$FIPS_TRUSTSTORE_PATH" 2>/dev/null

# Add FIPS keystore passwords to OpenSearch keystore
echo "Adding FIPS keystore passwords to OpenSearch keystore..."

echo "$FIPS_STORE_PASSWORD" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.keystore_password_secure
echo "$FIPS_STORE_PASSWORD" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.truststore_password_secure
echo "$FIPS_STORE_PASSWORD" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.keystore_password_secure
echo "$FIPS_STORE_PASSWORD" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.truststore_password_secure
echo "$FIPS_STORE_PASSWORD" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.keystore_keypassword_secure
echo "$FIPS_STORE_PASSWORD" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.keystore_keypassword_secure



# Add the keystore paths as well
echo "$FIPS_KEYSTORE_PATH" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.keystore_filepath 2>/dev/null
echo "$FIPS_TRUSTSTORE_PATH" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.truststore_filepath 2>/dev/null
echo "$FIPS_KEYSTORE_PATH" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.keystore_filepath 2>/dev/null
echo "$FIPS_TRUSTSTORE_PATH" | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.truststore_filepath 2>/dev/null

echo "FIPS keystores ready"
echo "Keystore location: $FIPS_KEYSTORE_PATH"
echo "Truststore location: $FIPS_TRUSTSTORE_PATH"
<% end %>