#!/usr/bin/env bash
export JOB_NAME=opensearch
export OPENSEARCH_HOME=/var/vcap/packages/opensearch
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config
export JAVA_HOME="/var/vcap/packages/opensearch/jdk"
export PATH="${JAVA_HOME}/bin:${PATH}"
export OPENSEARCH_SECURITY_CONFIG_PATH=${OPENSEARCH_PATH_CONF}/opensearch-security
export OPENSEARCH_JAVA_OPTS="-XX:-UsePerfData -Dnet.bytebuddy.agent.disabled=true -Djava.io.tmpdir=/var/vcap/data/opensearch/"
export YQ_PACKAGE_DIR=/var/vcap/packages/yq
export PATH=$YQ_PACKAGE_DIR/bin:$PATH
export TMP_DIR=/var/vcap/sys/tmp/$JOB_NAME
export PATH=/var/vcap/packages/cf-cli-8-linux/bin:$PATH
export KEYSTORE="${JAVA_HOME}/lib/security/cacerts"
STOREPASS=<%= p("opensearch.notification.keystorepass") %>
DEFAULTPASS=<%= p("opensearch.notification.defaultkeystorepass") %>

################################################################
# FIPS Configuration
################################################################
<% if p("opensearch.fips.enabled", false) %>
echo "Configuring OpenSearch for FIPS mode..."

# Create directories
mkdir -p /var/vcap/data/opensearch
chown vcap:vcap /var/vcap/data/opensearch
chmod 750 /var/vcap/data/opensearch

FIPS_LIB_DIR="/var/vcap/data/opensearch/fips-lib"
mkdir -p "${FIPS_LIB_DIR}"
JDK_LIB="${OPENSEARCH_HOME}/lib"

# Verify FIPS JARs exist in source
if ! ls ${OPENSEARCH_HOME}/lib/bc-fips-*.jar 1> /dev/null 2>&1; then
    echo "ERROR: FIPS enabled but FIPS JAR not found at ${OPENSEARCH_HOME}/lib"
    exit 1
fi

# Build FIPS classpath for keytool operations
FIPS_CP=""
for jar in bc-fips bctls-fips bcpkix-fips bcutil-fips; do
    src=$(ls ${JDK_LIB}/${jar}-*.jar 2>/dev/null | head -n1)
    if [ -z "$src" ] || [ ! -f "$src" ]; then
       echo "ERROR: FIPS enabled but ${jar}-*.jar not found in ${JDK_LIB}"
       exit 1
    fi
    
    dest="${FIPS_LIB_DIR}/$(basename "$src")"
    
    # Only copy if source and destination are different
    if [ "$src" != "$dest" ]; then
        cp "$src" "${FIPS_LIB_DIR}/"
        echo "Copied $(basename "$src") to ${FIPS_LIB_DIR}/"
    fi
    
    FIPS_CP="${FIPS_CP}:${FIPS_LIB_DIR}/$(basename "$src")"
done
FIPS_CP="${FIPS_CP#:}"
echo "FIPS classpath: ${FIPS_CP}"

# Set permissions on FIPS lib directory
chown -R vcap:vcap "${FIPS_LIB_DIR}"
chmod 750 "${FIPS_LIB_DIR}"
chmod 640 "${FIPS_LIB_DIR}"/*.jar

# Set FIPS keystore password and JVM options
export OPENSEARCH_KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"

# Add FIPS JVM options to existing OPENSEARCH_JAVA_OPTS
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -cp ${FIPS_CP}"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Dorg.bouncycastle.fips.approved_only=true"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djava.security.properties=${OPENSEARCH_PATH_CONF}/fips.security"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djavax.net.ssl.keyStoreType=BCFKS"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djavax.net.ssl.trustStoreType=BCFKS"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} --enable-native-access=ALL-UNNAMED"

# Additional FIPS flags from the PR
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Dcom.redhat.fips=false"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Dorg.bouncycastle.rsa.allow_unsafe_mod=true"

################################################################
# Create BCFKS Truststore and Keystore
################################################################
FIPS_KEYSTORE_PASS="<%= p('opensearch.fips.keystore_password', 'changeme') %>"
if [ ${#FIPS_KEYSTORE_PASS} -lt 14 ]; then 
  echo "WARN: Keystore password has to be at least 14 charafcters"
  exit 1
fi
export FIPS_KEYSTORE_PASS

BCFKS_TRUSTSTORE="${OPENSEARCH_PATH_CONF}/truststore.bcfks"
BCFKS_KEYSTORE="${OPENSEARCH_PATH_CONF}/keystore.bcfks"

# Path to CA certificates to import
CA_CERTS_SOURCE="${JAVA_HOME}/lib/security/cacerts"
DEFAULT_CACERTS_PASS="changeit"

echo "Creating BCFKS truststore and keystore for FIPS mode..."

# Create BCFKS truststore from existing CA certs
if [ ! -f "${BCFKS_TRUSTSTORE}" ]; then
    echo "Creating BCFKS truststore..."
    
    # Method 1: Convert existing cacerts to BCFKS format
    ${JAVA_HOME}/bin/keytool \
        -J--enable-native-access=ALL-UNNAMED \
        -J-Djava.io.tmpdir=/var/vcap/data/opensearch/ \
        -importkeystore \
        -srckeystore "${CA_CERTS_SOURCE}" \
        -srcstoretype JKS \
        -srcstorepass "${DEFAULT_CACERTS_PASS}" \
        -destkeystore "${BCFKS_TRUSTSTORE}" \
        -deststoretype BCFKS \
        -deststorepass "${FIPS_KEYSTORE_PASS}" \
        -providername BCFIPS \
        -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
        -providerpath "${FIPS_CP}" \
        -noprompt 2>/dev/null || {
            echo "Warning: keytool import failed, trying alternative method..."
            
            # Method 2: Create empty truststore and import certs individually
            ${JAVA_HOME}/bin/keytool \
                -J--enable-native-access=ALL-UNNAMED \
                -J-Djava.io.tmpdir=/var/vcap/data/opensearch/ \
                -genkeypair \
                -alias temp \
                -keyalg RSA \
                -keysize 2048 \
                -keystore "${BCFKS_TRUSTSTORE}" \
                -storetype BCFKS \
                -storepass "${FIPS_KEYSTORE_PASS}" \
                -providername BCFIPS \
                -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
                -providerpath "${FIPS_CP}" \
                -dname "CN=temp" \
                -validity 1 \
                -noprompt
            
            # Delete the temp key
            ${JAVA_HOME}/bin/keytool \
                -J--enable-native-access=ALL-UNNAMED \
                -J-Djava.io.tmpdir=/var/vcap/data/opensearch/ \
                -delete \
                -alias temp \
                -keystore "${BCFKS_TRUSTSTORE}" \
                -storetype BCFKS \
                -storepass "${FIPS_KEYSTORE_PASS}" \
                -providername BCFIPS \
                -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
                -providerpath "${FIPS_CP}" \
                -noprompt
        }
    
    echo "BCFKS truststore created at ${BCFKS_TRUSTSTORE}"
else
    echo "BCFKS truststore already exists at ${BCFKS_TRUSTSTORE}"
fi

# import custom CA certificates if provided
<% if_p('opensearch.fips.ca_certificate') do |ca_cert| %>
echo "Importing custom CA certificate into BCFKS truststore..."
CA_CERT_FILE="${OPENSEARCH_PATH_CONF}/ssl/fips-ca.pem"
mkdir -p "${OPENSEARCH_PATH_CONF}/ssl"
cat > "${CA_CERT_FILE}" << 'CACERT'
<%= ca_cert %>
CACERT

${JAVA_HOME}/bin/keytool \
    -J--enable-native-access=ALL-UNNAMED \
    -J-Djava.io.tmpdir=/var/vcap/data/opensearch/ \
    -importcert \
    -alias custom-ca \
    -file "${CA_CERT_FILE}" \
    -keystore "${BCFKS_TRUSTSTORE}" \
    -storetype BCFKS \
    -storepass "${FIPS_KEYSTORE_PASS}" \
    -providername BCFIPS \
    -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
    -providerpath "${FIPS_CP}" \
    -noprompt || echo "Warning: CA certificate import failed or already exists"
<% end %>

# Import node/transport certificates into truststore
<% if_p('opensearch.node.ssl.ca') do |node_ca| %>
echo "Importing node CA certificate into BCFKS truststore..."
NODE_CA_FILE="${OPENSEARCH_PATH_CONF}/ssl/node-ca.pem"
cat > "${NODE_CA_FILE}" << 'NODECA'
<%= node_ca %>
NODECA

${JAVA_HOME}/bin/keytool \
    -J--enable-native-access=ALL-UNNAMED \
    -J-Djava.io.tmpdir=/var/vcap/data/opensearch/ \
    -importcert \
    -alias node-ca \
    -file "${NODE_CA_FILE}" \
    -keystore "${BCFKS_TRUSTSTORE}" \
    -storetype BCFKS \
    -storepass "${FIPS_KEYSTORE_PASS}" \
    -providername BCFIPS \
    -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
    -providerpath "${FIPS_CP}" \
    -noprompt || echo "Warning: Node CA import failed or already exists"
<% end %>

# Create BCFKS keystore for node certificates
if [ ! -f "${BCFKS_KEYSTORE}" ]; then
    echo "Creating BCFKS keystore..."
    
    # ADD THIS DEBUGGING:
    echo "================================================================"
    echo "DEBUG: Keystore Creation Debug"
    echo "================================================================"
    echo "BCFKS_KEYSTORE path: ${BCFKS_KEYSTORE}"
    echo "TMP_DIR: ${TMP_DIR}"
    echo "FIPS_CP: ${FIPS_CP}"
    echo "FIPS JAR files:"
    ls -la "${FIPS_LIB_DIR}/"*.jar
    echo "================================================================"
    
    <% if_p('opensearch.node.ssl.private_key', 'opensearch.node.ssl.certificate') do |key, cert| %>
    echo "Found SSL certificates, creating keystore from PEM files..."
    
    # Create temporary PKCS12 from PEM files
    NODE_KEY_FILE="${OPENSEARCH_PATH_CONF}/ssl/opensearch-node.pem"
    NODE_CERT_FILE="${OPENSEARCH_PATH_CONF}/ssl/opensearch-node.crt"
    TEMP_P12="${TMP_DIR}/node-temp.p12"
    
    # ADD MORE DEBUGGING:
    echo "DEBUG: Certificate files:"
    echo "  NODE_KEY_FILE: ${NODE_KEY_FILE}"
    echo "  NODE_CERT_FILE: ${NODE_CERT_FILE}"
    echo "  TEMP_P12: ${TEMP_P12}"
    
    # Check if source files exist
    if [ -f "${NODE_KEY_FILE}" ]; then
        echo "✓ Key file exists"
        ls -la "${NODE_KEY_FILE}"
    else
        echo "✗ Key file missing: ${NODE_KEY_FILE}"
    fi
    
    if [ -f "${NODE_CERT_FILE}" ]; then
        echo "✓ Cert file exists"  
        ls -la "${NODE_CERT_FILE}"
    else
        echo "✗ Cert file missing: ${NODE_CERT_FILE}"
    fi
    
    # Ensure temp directory exists
    mkdir -p "${TMP_DIR}"
    
    # Combine key and cert into PKCS12
    echo "Creating PKCS12 with OpenSSL..."
    if ! openssl pkcs12 -export \
        -in "${NODE_CERT_FILE}" \
        -inkey "${NODE_KEY_FILE}" \
        -out "${TEMP_P12}" \
        -name "opensearch-node" \
        -passout "pass:${FIPS_KEYSTORE_PASS}"; then
        echo "ERROR: PKCS12 creation failed"
        exit 1
    fi
    
    # Verify PKCS12 was created
    echo "DEBUG: Verifying PKCS12 file..."
    if [ -f "${TEMP_P12}" ]; then
        echo "✓ PKCS12 file created successfully"
        ls -la "${TEMP_P12}"
        
        # Test PKCS12 can be read
        echo "Testing PKCS12 readability..."
        if openssl pkcs12 -info -in "${TEMP_P12}" -passin "pass:${FIPS_KEYSTORE_PASS}" -noout; then
            echo "✓ PKCS12 file is readable and valid"
        else
            echo "✗ PKCS12 file is corrupted or password wrong"
            exit 1
        fi
    else
        echo "✗ PKCS12 file was not created"
        exit 1
    fi
    
    # Convert PKCS12 to BCFKS
    echo "Converting PKCS12 to BCFKS..."
    echo "DEBUG: Keytool conversion parameters:"
    echo "  Source keystore: ${TEMP_P12}"
    echo "  Dest keystore: ${BCFKS_KEYSTORE}" 
    echo "  Provider class: org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider"
    echo "  Provider path: ${FIPS_CP}"
    
    if ! ${JAVA_HOME}/bin/keytool \
        -J--enable-native-access=ALL-UNNAMED \
        -J-Djava.io.tmpdir=/var/vcap/data/opensearch/ \
        -importkeystore \
        -srckeystore "${TEMP_P12}" \
        -srcstoretype PKCS12 \
        -srcstorepass "${FIPS_KEYSTORE_PASS}" \
        -destkeystore "${BCFKS_KEYSTORE}" \
        -deststoretype BCFKS \
        -deststorepass "${FIPS_KEYSTORE_PASS}" \
        -providername BCFIPS \
        -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
        -providerpath "${FIPS_CP}" \
        -noprompt; then
        echo "ERROR: BCFKS conversion failed!"
        echo "DEBUG: Keeping temp file for inspection: ${TEMP_P12}"
        exit 1
    fi
    
    echo "✓ BCFKS conversion completed successfully"
    
    # Test the created BCFKS keystore
    echo "DEBUG: Testing created BCFKS keystore..."
    if [ -f "${BCFKS_KEYSTORE}" ]; then
        echo "✓ BCFKS keystore file exists"
        ls -la "${BCFKS_KEYSTORE}"
        
        # Try to list contents (this might fail due to provider issues, but worth trying)
        echo "Attempting to list BCFKS keystore contents..."
        if ${JAVA_HOME}/bin/keytool -list \
            -keystore "${BCFKS_KEYSTORE}" \
            -storetype BCFKS \
            -storepass "${FIPS_KEYSTORE_PASS}" \
            -providername BCFIPS \
            -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
            -providerpath "${FIPS_CP}" 2>/dev/null; then
            echo "✓ BCFKS keystore validation successful"
        else
            echo "⚠ BCFKS keystore validation failed (might be provider issue)"
            echo "   But keystore file exists and conversion reported success"
        fi
    else
        echo "✗ BCFKS keystore file was not created"
        exit 1
    fi
    
    rm -f "${TEMP_P12}"
    echo "✓ Cleanup: Removed temporary PKCS12 file"
    <% end %>

# Set permissions on BCFKS stores
chown vcap:vcap "${BCFKS_TRUSTSTORE}" "${BCFKS_KEYSTORE}"
chmod 600 "${BCFKS_TRUSTSTORE}" "${BCFKS_KEYSTORE}"

# Create FIPS security properties file
mkdir -p "${OPENSEARCH_PATH_CONF}"
cat > "${OPENSEARCH_PATH_CONF}/fips.security" << EOF
# FIPS Security Configuration based on OpenSearch Security PR #6126
security.provider.1=org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider
security.provider.2=org.bouncycastle.jsse.provider.BouncyCastleJsseProvider fips:BCFIPS
security.provider.3=sun.security.provider.Sun
security.provider.4=sun.security.rsa.SunRsaSign
security.provider.5=sun.security.ec.SunEC

# Keystore configuration
keystore.type.compat=true
keystore.type=BCFKS

# SSL/TLS Configuration
ssl.KeyManagerFactory.algorithm=X509
ssl.TrustManagerFactory.algorithm=PKIX

# Protocol support
jdk.tls.client.protocols=TLSv1.2,TLSv1.3
jdk.tls.server.protocols=TLSv1.2,TLSv1.3

# FIPS-approved algorithms only
crypto.policy=unlimited
jdk.security.allowNonCaAnchor=true

# Disable weak algorithms
jdk.tls.disabledAlgorithms=SSLv2Hello, SSLv3, TLSv1, TLSv1.1, RC4, DES, MD5withRSA, DH keySize < 2048, EC keySize < 224, 3DES_EDE_CBC, anon, NULL
jdk.certpath.disabledAlgorithms=MD2, MD5, RSA keySize < 2048, DSA keySize < 2048, EC keySize < 224

# Additional FIPS configuration
securerandom.source=file:/dev/urandom
securerandom.strongAlgorithms=NativePRNGBlocking:SUN,DRBG:SUN
EOF

chown vcap:vcap "${OPENSEARCH_PATH_CONF}/fips.security"
chmod 640 "${OPENSEARCH_PATH_CONF}/fips.security"

# Store FIPS keystore password in a file for the startup script to use
KEYSTORE_PASS_FILE="${OPENSEARCH_PATH_CONF}/.keystore.pass"
echo "${FIPS_KEYSTORE_PASS}" > "${KEYSTORE_PASS_FILE}"
chown vcap:vcap "${KEYSTORE_PASS_FILE}"
chmod 600 "${KEYSTORE_PASS_FILE}"

export OPENSEARCH_KEYSTORE_PASSWORD="${FIPS_KEYSTORE_PASS}"

echo "FIPS mode configuration complete"
echo "  Truststore: ${BCFKS_TRUSTSTORE}"
echo "  Keystore: ${BCFKS_KEYSTORE}"

<% else %>
echo "FIPS mode disabled - using standard configuration"
export OPENSEARCH_FIPS_MODE=false
<% end %>

################################################################
# Existing keystore password change
################################################################
${JAVA_HOME}/bin/keytool -storepasswd -new $STOREPASS -cacerts -storepass "$DEFAULTPASS" > /dev/null 2>&1;

sysctl -q -w vm.max_map_count=262144

mkdir -p ${OPENSEARCH_HOME}/plugins

if [ -d ${JOB_DIR}/config/ssl ]; then
    chown vcap ${JOB_DIR}/config/ssl
fi

# source /var/vcap/packages/openjdk-21/bosh/runtime.env

# Copy default security config if it doesn't already exist
# Have to copy files that don't exist otherwise securityadmin.sh invocation will fail
cp -u ${OPENSEARCH_HOME}/config/opensearch-security/*.yml "$OPENSEARCH_SECURITY_CONFIG_PATH"

cd ${OPENSEARCH_HOME}

chown -R vcap:vcap config plugins
chown -R vcap:vcap "$OPENSEARCH_SECURITY_CONFIG_PATH"

<% if_p('opensearch.cf.domain', 'opensearch.cf.client_id', 'opensearch.cf.client_password') do %>
<% if p("opensearch.node.allow_data") %>
<%
  api = p("opensearch.cf.domain")
  client = p("opensearch.cf.client_id")
  password = p("opensearch.cf.client_password")
%>

cf api "<%= api %>"
cf auth "<%= client %>" "<%= password %>" --client-credentials

# Prepare tenants, roles, and role mappings so that they don't get overridden by securityadmin.sh
# script invocation in post-start
ORG_GUID_LIST=()
for org in $(cf orgs | tail -n +4); do
  ORG_GUID=$(cf org "$org" --guid)
  ROLE_NAME="$org-tenant"
  ORG_GUID_LIST+=("\"$ORG_GUID\"")
  yq -i ".\"$org\"={\"description\":\"tenant for $org\"}" "$OPENSEARCH_SECURITY_CONFIG_PATH/tenants.yml"
  yq -i ".\"$ROLE_NAME\"={\"tenant_permissions\":[{\"tenant_patterns\":[\"$org\"],\"allowed_actions\":[\"kibana_all_write\"]}]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles.yml"
  yq -i ".\"$ROLE_NAME\"={\"backend_roles\": [\"$ORG_GUID\"]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
done

# this makes a list of cf org guids and assigns them to roles, making users with a org have access to the following roles.
ORG_GUID_ROLE_LIST=$(IFS=,; echo "${ORG_GUID_LIST[*]}")
yq -i ".cf_user={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".reports_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".alerting_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".notifications_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"

<% end %>
<% end %>

# Plugin installations
<% if_p('opensearch.repository.s3.access_key', 'opensearch.repository.s3.secret_key') do %>
  ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b repository-s3
  echo '<%= p('opensearch.repository.s3.access_key') %>' \
    | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin s3.client.default.access_key
  echo '<%= p('opensearch.repository.s3.secret_key') %>' \
    | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin s3.client.default.secret_key
<% end %>

<% p("opensearch.plugins").each do |plugin| name, path = plugin.first %>
  <% if path.start_with? '/var/vcap' %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "file://<%= path %>"
  <% elsif path.start_with? 'http' %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "<%= path %>"
  <% else %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "<%= path %>"
  <% end %>
<% end %>

log_dir=${OPENSEARCH_HOME}/logs
if [[ ! -a ${log_dir} ]]; then
  ln -s /var/vcap/sys/log/opensearch ${log_dir}
fi

# Create new OpenSearch keystore
if [ ! -f "$OPENSEARCH_PATH_CONF/opensearch.keystore" ]; then
  echo "Creating new OpenSearch keystore"
  # Clean up any temporary files from previous attempts
  rm -f "$OPENSEARCH_PATH_CONF/opensearch.keystore.tmp"
  rm -f "$OPENSEARCH_PATH_CONF/opensearch.keystore.tmp.*"
fi 

<% if p("opensearch.fips.enabled", false) %>
echo "Creating FIPS-compliant keystore..."
rm -f "$OPENSEARCH_PATH_CONF/opensearch.keystore"*

# FIPS requires passwords to be at least 112 bits (14 characters)
KEYSTORE_PASS="${FIPS_KEYSTORE_PASS}"

# Set FIPS environment
export FIPS_KEYSTORE_OPTS="${OPENSEARCH_JAVA_OPTS} -Dorg.bouncycastle.fips.approved_only=true -Djava.security.properties=${OPENSEARCH_PATH_CONF}/fips.security"

echo "Creating FIPS keystore with compliant password (${#KEYSTORE_PASS} characters)..."
KEYSTORE_CREATED=false

# Try with FIPS-compliant password
if {
    echo "${KEYSTORE_PASS}"
    echo "${KEYSTORE_PASS}"
} | OPENSEARCH_JAVA_OPTS="${FIPS_KEYSTORE_OPTS}" "$PACKAGE_DIR/bin/opensearch-keystore" create --password 2>/dev/null; then
    echo "✓ FIPS keystore created with password"
    KEYSTORE_CREATED=true
fi

# Fallback: Create without password if password creation fails
if [ "$KEYSTORE_CREATED" = false ]; then
    echo "Password creation failed, creating keystore without password..."
    rm -f "$OPENSEARCH_PATH_CONF/opensearch.keystore"*
    
    if echo y | OPENSEARCH_JAVA_OPTS="${FIPS_KEYSTORE_OPTS}" "$PACKAGE_DIR/bin/opensearch-keystore" create 2>/dev/null; then
        echo "✓ FIPS keystore created without password"
        KEYSTORE_CREATED=true
    fi
fi

# Final fallback: Relaxed FIPS mode
if [ "$KEYSTORE_CREATED" = false ]; then
    echo "Trying with relaxed FIPS settings..."
    rm -f "$OPENSEARCH_PATH_CONF/opensearch.keystore"*
    
    export FIPS_RELAXED_OPTS="${OPENSEARCH_JAVA_OPTS} -Dorg.bouncycastle.fips.approved_only=false -Djava.security.properties=${OPENSEARCH_PATH_CONF}/fips.security"
    
    if echo y | OPENSEARCH_JAVA_OPTS="${FIPS_RELAXED_OPTS}" "$PACKAGE_DIR/bin/opensearch-keystore" create 2>/dev/null; then
        echo "✓ FIPS keystore created with relaxed settings"
        KEYSTORE_CREATED=true
    fi
fi

if [ "$KEYSTORE_CREATED" = false ]; then
    echo "ERROR: All FIPS keystore creation methods failed"
    exit 1
fi

echo "FIPS keystore setup complete"
<% else %>
# Non-FIPS mode
echo "Creating standard keystore..."
echo y | "$PACKAGE_DIR/bin/opensearch-keystore" create
<% end %>

# Verify keystore exists and set permissions
if [ -f "$OPENSEARCH_PATH_CONF/opensearch.keystore" ]; then
  chown vcap:vcap "$OPENSEARCH_PATH_CONF/opensearch.keystore"
  chmod 600 "$OPENSEARCH_PATH_CONF/opensearch.keystore"
  echo "✓ Keystore permissions set successfully"
else
  echo "ERROR: Failed to create OpenSearch keystore"
  exit 1
fi

echo "Setting final permissions..."

# FIPS-specific permissions (only if FIPS is enabled)
<% if p("opensearch.fips.enabled", false) %>
FIPS_LIB_DIR="/var/vcap/data/opensearch/fips-lib"
if [ -f "${OPENSEARCH_PATH_CONF}/fips.security" ]; then
  chown vcap:vcap "${OPENSEARCH_PATH_CONF}/fips.security"
  chmod 640 "${OPENSEARCH_PATH_CONF}/fips.security"
fi
if [ -d "${FIPS_LIB_DIR}" ]; then
  chown -R vcap:vcap "${FIPS_LIB_DIR}"
  chmod 750 "${FIPS_LIB_DIR}"
  chmod 640 "${FIPS_LIB_DIR}"/*.jar 2>/dev/null || true
fi
<% end %>

# ADD FINAL DEBUGGING SECTION:
echo "================================================================"
echo "DEBUG: Final Configuration Verification"
echo "================================================================"

<% if p("opensearch.fips.enabled", false) %>
echo "FIPS Configuration Summary:"
echo "  FIPS enabled: true"
echo "  Keystore password: [${#FIPS_KEYSTORE_PASS} characters]"
echo "  BCFKS Keystore: ${BCFKS_KEYSTORE}"
echo "  BCFKS Truststore: ${BCFKS_TRUSTSTORE}"

# Check keystore files exist
for store in "${BCFKS_KEYSTORE}" "${BCFKS_TRUSTSTORE}"; do
    if [ -f "$store" ]; then
        echo "✓ $(basename $store) exists ($(stat -c%s $store) bytes)"
        ls -la "$store"
    else
        echo "✗ $(basename $store) missing: $store"
    fi
done

# Show what OpenSearch config will use
echo "OpenSearch SSL configuration will use:"
grep -E "(keystore_password|keystore_filepath)" /var/vcap/jobs/opensearch/config/opensearch.yml 2>/dev/null || echo "  [OpenSearch config not yet generated]"

echo "Environment variables:"
echo "  OPENSEARCH_KEYSTORE_PASSWORD: ${OPENSEARCH_KEYSTORE_PASSWORD:-[not set]}"
echo "  FIPS_KEYSTORE_PASS: ${FIPS_KEYSTORE_PASS:-[not set]}"
<% else %>
echo "FIPS Configuration: disabled"
<% end %>

echo "================================================================"
echo "Pre-start complete"