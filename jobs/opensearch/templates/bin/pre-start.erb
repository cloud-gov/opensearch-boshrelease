#!/usr/bin/env bash
export JOB_NAME=opensearch
export OPENSEARCH_HOME=/var/vcap/packages/opensearch
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config
export OPENSEARCH_SECURITY_CONFIG_PATH=${OPENSEARCH_PATH_CONF}/opensearch-security
export OPENSEARCH_JAVA_OPTS="-XX:-UsePerfData -Dnet.bytebuddy.agent.disabled=true -Djava.io.tmpdir=/var/vcap/data/opensearch/"
export YQ_PACKAGE_DIR=/var/vcap/packages/yq
export PATH=$YQ_PACKAGE_DIR/bin:$PATH
export PATH=/var/vcap/packages/cf-cli-8-linux/bin:$PATH
export KEYSTORE="/var/vcap/packages/openjdk-21/lib/security/cacerts"
STOREPASS=<%= p("opensearch.notification.keystorepass") %>
DEFAULTPASS=<%= p("opensearch.notification.defaultkeystorepass") %>

################################################################
# FIPS Configuration
################################################################
<% if p("opensearch.fips.enabled", false) %>
echo "Configuring OpenSearch for FIPS mode..."

# Check if FIPS JAR is available
FIPS_JAR_PATH="/var/vcap/packages/openjdk-21/lib/bc-fips-2.1.2.jar"
if ! ls "$FIPS_JAR_PATH" 1> /dev/null 2>&1; then
    echo "ERROR: FIPS enabled but FIPS JAR not found at $FIPS_JAR_PATH"
    exit 1
fi

# Create directories and copy FIPS JAR early
mkdir -p /var/vcap/data/opensearch
FIPS_LIB_DIR="/var/vcap/data/opensearch/fips-lib"
mkdir -p "${FIPS_LIB_DIR}"
cp "${FIPS_JAR_PATH}" "${FIPS_LIB_DIR}/"
FIPS_JAR_COPY="${FIPS_LIB_DIR}/bc-fips-2.1.2.jar"

# Create FIPS security properties file
mkdir -p "${OPENSEARCH_PATH_CONF}"
cat > "${OPENSEARCH_PATH_CONF}/fips.security" << EOF
security.provider.1=org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider
security.provider.2=sun.security.provider.Sun
security.provider.3=sun.security.rsa.SunRsaSign
security.provider.4=sun.security.ec.SunEC
security.provider.5=com.sun.net.ssl.internal.ssl.Provider
security.provider.6=com.sun.crypto.provider.SunJCE

org.bouncycastle.fips.approved_only=<%= p('opensearch.fips.strict', true) %>

jdk.tls.disabledAlgorithms=SSLv2Hello, SSLv3, TLSv1, TLSv1.1, RC4, DES, MD5withRSA, DH keySize < 2048, EC keySize < 224, 3DES_EDE_CBC, anon, NULL
jdk.certpath.disabledAlgorithms=MD2, MD5, SHA1 jdkCA & usage TLSServer, RSA keySize < 2048, DSA keySize < 2048, EC keySize < 224
EOF

# Set FIPS keystore password
export OPENSEARCH_KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"

# Add FIPS JVM options immediately
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -cp ${FIPS_JAR_COPY}"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Dorg.bouncycastle.fips.approved_only=<%= p('opensearch.fips.strict', true) %>"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djava.security.properties=${OPENSEARCH_PATH_CONF}/fips.security"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djavax.net.ssl.keyStoreType=BCFKS"
export OPENSEARCH_JAVA_OPTS="${OPENSEARCH_JAVA_OPTS} -Djavax.net.ssl.trustStoreType=BCFKS"

# Create wrapper function for FIPS-enabled keytool
fips_keytool() {
    /var/vcap/packages/openjdk-21/bin/keytool \
        -J-cp -J"${FIPS_JAR_COPY}" \
        -J-Djava.security.properties="${OPENSEARCH_PATH_CONF}/fips.security" \
        "$@"
}

export OPENSEARCH_FIPS_MODE=true
echo "FIPS mode enabled"
<% else %>
echo "FIPS mode disabled - using standard configuration"
export OPENSEARCH_FIPS_MODE=false
<% end %>

################################################################
# Existing keystore password change
################################################################
/var/vcap/packages/openjdk-21/bin/keytool -storepasswd -new $STOREPASS -cacerts -storepass "$DEFAULTPASS" > /dev/null 2>&1;

sysctl -q -w vm.max_map_count=262144
mkdir -p ${OPENSEARCH_HOME}/plugins

if [ -d ${JOB_DIR}/config/ssl ]; then
    chown vcap ${JOB_DIR}/config/ssl
fi

source /var/vcap/packages/openjdk-21/bosh/runtime.env

# Copy default security config if it doesn't already exist
# Have to copy files that don't exist otherwise securityadmin.sh invocation will fail
cp -u ${OPENSEARCH_HOME}/config/opensearch-security/*.yml "$OPENSEARCH_SECURITY_CONFIG_PATH"

cd ${OPENSEARCH_HOME}
chown -R vcap:vcap config plugins
chown -R vcap:vcap "$OPENSEARCH_SECURITY_CONFIG_PATH"

<% if_p('opensearch.cf.domain', 'opensearch.cf.client_id', 'opensearch.cf.client_password') do %>
<% if p("opensearch.node.allow_data") %>
<%
  api = p("opensearch.cf.domain")
  client = p("opensearch.cf.client_id")
  password = p("opensearch.cf.client_password")
%>
cf api "<%= api %>"
cf auth "<%= client %>" "<%= password %>" --client-credentials

# Prepare tenants, roles, and role mappings so that they don't get overridden by securityadmin.sh
# script invocation in post-start
ORG_GUID_LIST=()
for org in $(cf orgs | tail -n +4); do
  ORG_GUID=$(cf org "$org" --guid)
  ROLE_NAME="$org-tenant"
  ORG_GUID_LIST+=("\"$ORG_GUID\"")
  yq -i ".\"$org\"={\"description\":\"tenant for $org\"}" "$OPENSEARCH_SECURITY_CONFIG_PATH/tenants.yml"
  yq -i ".\"$ROLE_NAME\"={\"tenant_permissions\":[{\"tenant_patterns\":[\"$org\"],\"allowed_actions\":[\"kibana_all_write\"]}]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles.yml"
  yq -i ".\"$ROLE_NAME\"={\"backend_roles\": [\"$ORG_GUID\"]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
done

# this makes a list of cf org guids and assigns them to roles, making users with a org have access to the following roles.
ORG_GUID_ROLE_LIST=$(IFS=,; echo "${ORG_GUID_LIST[*]}")
yq -i ".cf_user={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".reports_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".alerting_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
yq -i ".notifications_full_access={\"backend_roles\": [$ORG_GUID_ROLE_LIST]}" "$OPENSEARCH_SECURITY_CONFIG_PATH/roles_mapping.yml"
<% end %>
<% end %>

# Plugin installations
<% if_p('opensearch.repository.s3.access_key', 'opensearch.repository.s3.secret_key') do %>
  ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b repository-s3
  echo '<%= p('opensearch.repository.s3.access_key') %>' \
    | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin s3.client.default.access_key
  echo '<%= p('opensearch.repository.s3.secret_key') %>' \
    | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin s3.client.default.secret_key
<% end %>

<% p("opensearch.plugins").each do |plugin| name, path = plugin.first %>
  <% if path.start_with? '/var/vcap' %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "file://<%= path %>"
  <% elsif path.start_with? 'http' %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "<%= path %>"
  <% else %>
    ${OPENSEARCH_HOME}/bin/opensearch-plugin install -b "<%= path %>"
  <% end %>
<% end %>

log_dir=${OPENSEARCH_HOME}/logs
if [[ ! -a ${log_dir} ]]; then
  ln -s /var/vcap/sys/log/opensearch ${log_dir}
fi

<% if p("opensearch.fips.enabled", false) %>
# Set minimum 6-character password for FIPS mode
export OPENSEARCH_KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"
<% end %>

# Create new OpenSearch keystore (FIXED)
if [ ! -f "$OPENSEARCH_PATH_CONF/opensearch.keystore" ]; then
  echo "Create new OpenSearch keystore"
  echo y | "$PACKAGE_DIR/bin/opensearch-keystore" create
fi

if [ -f "$OPENSEARCH_PATH_CONF/opensearch.keystore" ]; then
  chown vcap:vcap "$OPENSEARCH_PATH_CONF/opensearch.keystore"
  chmod 600 "$OPENSEARCH_PATH_CONF/opensearch.keystore"
else
  echo "ERROR: Failed to create OpenSearch keystore"
  exit 1
fi

################################################################
# FIPS Keystore Setup 
################################################################
<% if p("opensearch.fips.enabled", false) %>
echo "Setting up FIPS keystores..."

# FIPS keystore/truststore setup
FIPS_KEYSTORE_PATH="/var/vcap/data/opensearch/keystore.bcfks"
FIPS_TRUSTSTORE_PATH="/var/vcap/data/opensearch/truststore.bcfks"
FIPS_STORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"

# Validate password length
if [ ${#FIPS_STORE_PASSWORD} -lt 6 ]; then
    echo "ERROR: FIPS keystore password must be at least 6 characters long"
    exit 1
fi

echo "Testing FIPS keytool functionality..."
if fips_keytool -list -keystore /dev/null -storetype BCFKS -storepass password123 2>/dev/null; then
    echo "FIPS keytool test successful"
else
    echo "Testing basic FIPS provider availability..."
    # Alternative test - try to create a temporary keystore
    if fips_keytool -genkeypair -alias test -keyalg RSA -keysize 2048 \
        -keystore /tmp/test.bcfks -storetype BCFKS \
        -storepass password123 -keypass password123 \
        -dname "CN=test" -validity 1 2>/dev/null; then
        rm -f /tmp/test.bcfks
        echo "FIPS keytool working via alternative test"
    else
        echo "ERROR: FIPS keytool not working. Check FIPS configuration."
        exit 1
    fi
fi

# Create FIPS keystore if it doesn't exist
if [ ! -f "$FIPS_KEYSTORE_PATH" ]; then
    echo "Creating FIPS keystore..."
    fips_keytool -genkeypair \
        -alias opensearch-node \
        -keyalg RSA \
        -keysize 2048 \
        -validity 365 \
        -keystore "$FIPS_KEYSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -keypass "$FIPS_STORE_PASSWORD" \
        -dname "CN=<%= spec.address || spec.name %>, O=GSA, C=US"
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create FIPS keystore"
        exit 1
    fi
    echo "FIPS keystore created successfully"
fi

# Create FIPS truststore if it doesn't exist  
if [ ! -f "$FIPS_TRUSTSTORE_PATH" ]; then
    echo "Creating FIPS truststore..."
    
    # Export cert from keystore
    fips_keytool -exportcert \
        -alias opensearch-node \
        -keystore "$FIPS_KEYSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file /tmp/opensearch-cert.pem
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to export certificate from keystore"
        exit 1
    fi
    
    # Import cert to truststore
    fips_keytool -importcert \
        -alias opensearch-ca \
        -keystore "$FIPS_TRUSTSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file /tmp/opensearch-cert.pem \
        -noprompt
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create FIPS truststore"
        rm -f /tmp/opensearch-cert.pem
        exit 1
    fi
    
    rm -f /tmp/opensearch-cert.pem
    echo "FIPS truststore created successfully"
fi

<% if_p('opensearch.fips.ca_certificate') do |ca_cert| %>
# Import provided CA certificate
echo "Importing provided CA certificate..."
echo "<%= ca_cert %>" > /tmp/ca-cert.pem

fips_keytool -importcert \
    -alias provided-ca \
    -keystore "$FIPS_TRUSTSTORE_PATH" \
    -storetype BCFKS \
    -storepass "$FIPS_STORE_PASSWORD" \
    -file /tmp/ca-cert.pem \
    -noprompt

if [ $? -eq 0 ]; then
    echo "CA certificate imported successfully"
else
    echo "WARNING: Failed to import CA certificate"
fi

rm -f /tmp/ca-cert.pem
<% end %>

# Set proper permissions for FIPS keystores
chown vcap:vcap "$FIPS_KEYSTORE_PATH" "$FIPS_TRUSTSTORE_PATH" 2>/dev/null
chmod 600 "$FIPS_KEYSTORE_PATH" "$FIPS_TRUSTSTORE_PATH" 2>/dev/null

# Add FIPS keystore passwords to OpenSearch keystore
echo "Adding FIPS keystore passwords to OpenSearch keystore..."

echo "$FIPS_STORE_PASSWORD" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.keystore_password 2>/dev/null
echo "$FIPS_STORE_PASSWORD" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.truststore_password 2>/dev/null
echo "$FIPS_STORE_PASSWORD" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.keystore_password 2>/dev/null
echo "$FIPS_STORE_PASSWORD" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.truststore_password 2>/dev/null

# Add the keystore paths as well
echo "$FIPS_KEYSTORE_PATH" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.keystore_filepath 2>/dev/null
echo "$FIPS_TRUSTSTORE_PATH" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.transport.truststore_filepath 2>/dev/null
echo "$FIPS_KEYSTORE_PATH" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.keystore_filepath 2>/dev/null
echo "$FIPS_TRUSTSTORE_PATH" | ${OPENSEARCH_HOME}/bin/opensearch-keystore add --stdin plugins.security.ssl.http.truststore_filepath 2>/dev/null

echo "FIPS keystores ready"
echo "Keystore location: $FIPS_KEYSTORE_PATH"
echo "Truststore location: $FIPS_TRUSTSTORE_PATH"
<% end %>