#!/usr/bin/env bash
set -Eeuo pipefail
export JQ_PACKAGE_DIR=/var/vcap/packages/jq
export AWS_PACKAGE_DIR=/var/vcap/packages/awscli
export PATH=$JQ_PACKAGE_DIR/bin:$AWS_PACKAGE_DIR/bin:$PATH
export JOB_NAME=opensearch
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export STORE_DIR=/var/vcap/store/$JOB_NAME
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME

CA="--cacert ${JOB_DIR}/config/ssl/opensearch.ca"
CERT="--cert ${JOB_DIR}/config/ssl/opensearch-admin.crt"
KEY="--key ${JOB_DIR}/config/ssl/opensearch-admin.key"

# Handle AWS Secrets Manager (existing functionality)
<% if_p('opensearch.notifications.secrets_prefix') do |prefix| %>
  for SECRET_NAME in $(aws secretsmanager list-secrets --filters Key=name,Values=<%= prefix %> | jq -r '.SecretList[].Name'); do
    SECRET_DATA=$(aws secretsmanager get-secret-value --secret-id "$SECRET_NAME" | jq -r '.SecretString')
    SENDER_NAME=$(echo "$SECRET_DATA" | jq -r '.email_sender_name')
    USERNAME=$(echo "$SECRET_DATA" | jq -r '.smtp_username')
    PASSWORD=$(echo "$SECRET_DATA" | jq -r '.smtp_password')
    echo "adding username for $SENDER_NAME to keystore"
    echo "$USERNAME" | "$PACKAGE_DIR/bin/opensearch-keystore" add "opensearch.notifications.core.email.$SENDER_NAME.username" --stdin -f
    echo "adding password for $SENDER_NAME to keystore"
    echo "$PASSWORD" | "$PACKAGE_DIR/bin/opensearch-keystore" add "opensearch.notifications.core.email.$SENDER_NAME.password" --stdin -f
  done
  # Errand runs as root, so make sure file goes back to vcap ownership
  chown vcap:vcap "$OPENSEARCH_PATH_CONF/opensearch.keystore"
  
  # Reload nodes to recognize new keystore values
  curl -X POST \
    ${CA} ${CERT} ${KEY} \
    -s https://localhost:9200/_nodes/reload_secure_settings
<% end %>

<% if_p('opensearch.notifications.email_accounts') do |email_accounts| %>
  <% email_accounts.each do |account| %>
    SENDER_NAME="<%= account['name'] %>"
    SMTP_HOST="<%= account.fetch('smtp_host', 'smtp.gmail.com') %>"
    SMTP_PORT="<%= account.fetch('smtp_port', 587) %>"
    SMTP_METHOD="<%= account.fetch('smtp_method', 'start_tls') %>"
    FROM_ADDRESS="<%= account.fetch('from_address', account['name'] + '@gsa.gov') %>"
    
    echo "Creating email account: $SENDER_NAME"
    
    # Create email account payload (credentials come from keystore)
    cat > /tmp/email_account_${SENDER_NAME}.json <<EOF
{
  "id": "${SENDER_NAME}",
  "name": "${SENDER_NAME}",
  "config": {
    "name": "${SENDER_NAME}",
    "description": "Email account for ${SENDER_NAME}",
    "config_type": "smtp_account",
    "is_enabled": true,
    "smtp_account": {
      "method": "${SMTP_METHOD}",
      "host": "${SMTP_HOST}",
      "port": ${SMTP_PORT},
      "from_address": "${FROM_ADDRESS}"
    }
  }
}
EOF
    
    cat /tmp/email_account_${SENDER_NAME}.json
    
    curl -X POST \
      ${CA} ${CERT} ${KEY} \
      -H "Content-Type: application/json" \
      -d @/tmp/email_account_${SENDER_NAME}.json \
      -s "https://localhost:9200/_plugins/_notifications/configs/" \
      || echo "Failed to create email account: ${SENDER_NAME}"
      
    rm -f /tmp/email_account_${SENDER_NAME}.json
    
    echo "Email account ${SENDER_NAME} configured"
  <% end %>
<% end %>

<% if_p('opensearch.notifications.channels') do |channels| %>
  <% channels.each do |channel| %>
    echo "Creating notification channel: <%= channel['name'] %>"
    
    cat > /tmp/channel_<%= channel['name'] %>.json <<EOF
{
  "id": "<%= channel['name'] %>",
  "name": "<%= channel['name'] %>",
  "config": {
    "name": "<%= channel.fetch('display_name', channel['name']) %>",
    "description": "<%= channel.fetch('description', 'Auto-generated channel') %>",
    "config_type": "<%= channel.fetch('type', 'email') %>",
    "is_enabled": <%= channel.fetch('enabled', true) %>,
    "email": {
      "email_account_id": "<%= channel.fetch('sender_name', '') %>",
      "recipient_list": [
      <% channel['users'].each_with_index do |user, index| %>
        <% if index > 0 %>,
      <% end %>  {
          "recipient": "<%= user %>"
        }<% end %>
      ]
      <% if channel['subject'] %>
      ,"subject": "<%= channel['subject'] %>"
      <% end %>
      <% if channel['message'] %>
      ,"message": "<%= channel['message'] %>"
      <% end %>
    }
  }
}
EOF
    # Create the channel using POST (for new channels)
    curl -X POST \
      ${CA} ${CERT} ${KEY} \
      -H "Content-Type: application/json" \
      -d @/tmp/channel_<%= channel['name'] %>.json \
      -s "https://localhost:9200/_plugins/_notifications/configs/" \
      || echo "Failed to create channel: <%= channel['name'] %>"
      
    # Clean up temp file
    rm -f /tmp/channel_<%= channel['name'] %>.json
      
    echo "Channel <%= channel['name'] %> configured"
  <% end %>
<% end %>

exit 0