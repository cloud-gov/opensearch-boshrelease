#!/usr/bin/env bash
set -Eeuo pipefail
export JQ_PACKAGE_DIR=/var/vcap/packages/jq
export AWS_PACKAGE_DIR=/var/vcap/packages/awscli
export PATH=$JQ_PACKAGE_DIR/bin:$AWS_PACKAGE_DIR/bin:$PATH
export JOB_NAME=opensearch
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export STORE_DIR=/var/vcap/store/$JOB_NAME
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config
export OPENSEARCH_JAVA_OPTS="-XX:-UsePerfData -Dnet.bytebuddy.agent.disabled=true -Djava.io.tmpdir=/var/vcap/data/opensearch/"
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME

CA="--cacert ${JOB_DIR}/config/ssl/opensearch.ca"
CERT="--cert ${JOB_DIR}/config/ssl/opensearch-admin.crt"
KEY="--key ${JOB_DIR}/config/ssl/opensearch-admin.key"

<% if_p('opensearch.repository.s3.access_key', 'opensearch.repository.s3.secret_key') do |access_key, secret_key| %>
echo "Adding S3 credentials to keystore..."
echo "<%= access_key %>" | "$PACKAGE_DIR/bin/opensearch-keystore" add "s3.client.default.access_key" --stdin -f
echo "<%= secret_key %>" | "$PACKAGE_DIR/bin/opensearch-keystore" add "s3.client.default.secret_key" --stdin -f
<% end %>

<% if_p('opensearch.notifications.secrets_prefix') do |prefix| %>
  for SECRET_NAME in $(aws secretsmanager list-secrets --filters Key=name,Values=<%= prefix %> | jq -r '.SecretList[].Name'); do
    SECRET_DATA=$(aws secretsmanager get-secret-value --secret-id "$SECRET_NAME" | jq -r '.SecretString')
    SENDER_NAME=$(echo "$SECRET_DATA" | jq -r '.email_sender_name')
    USERNAME=$(echo "$SECRET_DATA" | jq -r '.smtp_username')
    PASSWORD=$(echo "$SECRET_DATA" | jq -r '.smtp_password')
    echo "adding username for $SENDER_NAME to keystore"
    echo "$USERNAME" | "$PACKAGE_DIR/bin/opensearch-keystore" add "opensearch.notifications.core.email.$SENDER_NAME.username" --stdin -f
    echo "adding password for $SENDER_NAME to keystore"
    echo "$PASSWORD" | "$PACKAGE_DIR/bin/opensearch-keystore" add "opensearch.notifications.core.email.$SENDER_NAME.password" --stdin -f
  done
  # Errand runs as root, so make sure file goes back to vcap ownership
  chown vcap:vcap "$OPENSEARCH_PATH_CONF/opensearch.keystore"
  
  # Reload nodes to recognize new keystore values
  curl -X POST \
    ${CA} ${CERT} ${KEY} \
    -s https://localhost:9200/_nodes/reload_secure_settings
<% end %>

<% if_p('opensearch.notifications.email_accounts') do |email_accounts| %>
  # Initialize mapping file
  > /tmp/email_account_mappings.txt
  
  <% email_accounts.each do |account| %>
    SENDER_NAME="<%= account['name'] %>"
    SMTP_HOST="<%= account.fetch('smtp_host', 'smtp.gmail.com') %>"
    SMTP_PORT="<%= account.fetch('smtp_port', 587) %>"
    SMTP_METHOD="<%= account.fetch('smtp_method', 'start_tls') %>"
    FROM_ADDRESS="<%= account.fetch('from_address', account['name'] + '@gsa.gov') %>"
    
    echo "Processing email account: $SENDER_NAME"
    
    # Check if account already exists
    EXISTING_ACCOUNT=$(curl -X GET \
      ${CA} ${CERT} ${KEY} \
      -s "https://localhost:9200/_plugins/_notifications/configs" | jq -r '.config_list[]? | select(.config.name=="'${SENDER_NAME}'" and .config.config_type=="smtp_account") | .config_id')
    
    # Create email account payload
    cat > /tmp/email_account_${SENDER_NAME}.json <<EOF
{
  "config": {
    "name": "${SENDER_NAME}",
    "description": "Email account for ${SENDER_NAME}",
    "config_type": "smtp_account",
    "is_enabled": true,
    "smtp_account": {
      "method": "${SMTP_METHOD}",
      "host": "${SMTP_HOST}",
      "port": ${SMTP_PORT},
      "from_address": "${FROM_ADDRESS}"
    }
  }
}
EOF
    
    if [ -n "$EXISTING_ACCOUNT" ]; then
      echo "Updating existing email account: $SENDER_NAME (config_id: ${EXISTING_ACCOUNT})"
      
      # Update the email account using PUT
      RESPONSE=$(curl -X PUT \
        ${CA} ${CERT} ${KEY} \
        -H "Content-Type: application/json" \
        -d @/tmp/email_account_${SENDER_NAME}.json \
        -s "https://localhost:9200/_plugins/_notifications/configs/${EXISTING_ACCOUNT}")
      
      if echo "$RESPONSE" | jq -e '.config_id' > /dev/null 2>&1; then
        echo "Email account ${SENDER_NAME} updated successfully"
        echo "${SENDER_NAME}:${EXISTING_ACCOUNT}" >> /tmp/email_account_mappings.txt
      else
        echo "Failed to update email account: ${SENDER_NAME}"
        echo "Response: $RESPONSE"
      fi
      
    else
      echo "Creating new email account: $SENDER_NAME"
      
      # Add id and name fields for POST requests
      jq '. + {"id": "'${SENDER_NAME}'", "name": "'${SENDER_NAME}'"}' /tmp/email_account_${SENDER_NAME}.json > /tmp/email_account_${SENDER_NAME}_post.json
      
      # Create the email account and capture the response
      RESPONSE=$(curl -X POST \
        ${CA} ${CERT} ${KEY} \
        -H "Content-Type: application/json" \
        -d @/tmp/email_account_${SENDER_NAME}_post.json \
        -s "https://localhost:9200/_plugins/_notifications/configs/")
      
      if echo "$RESPONSE" | jq -e '.config_id' > /dev/null 2>&1; then
        CONFIG_ID=$(echo "$RESPONSE" | jq -r '.config_id')
        echo "Email account ${SENDER_NAME} created successfully with config_id: ${CONFIG_ID}"
        echo "${SENDER_NAME}:${CONFIG_ID}" >> /tmp/email_account_mappings.txt
      else
        echo "Failed to create email account: ${SENDER_NAME}"
        echo "Response: $RESPONSE"
      fi
      
      rm -f /tmp/email_account_${SENDER_NAME}_post.json
    fi
        
    rm -f /tmp/email_account_${SENDER_NAME}.json
  <% end %>
  
  echo "Email account mappings:"
  cat /tmp/email_account_mappings.txt
<% end %>

<% if_p('opensearch.notifications.channels') do |channels| %>
  <% channels.each do |channel| %>
    echo "Processing notification channel: <%= channel['name'] %>"
    
    SENDER_NAME="<%= channel.fetch('sender_name', '') %>"
    EMAIL_ACCOUNT_ID="$SENDER_NAME"
    CHANNEL_DISPLAY_NAME="<%= channel.fetch('display_name', channel['name']) %>"
    
    # Check if we have a config_id mapping for this sender
    if [ -f "/tmp/email_account_mappings.txt" ] && [ -n "$SENDER_NAME" ]; then
      MAPPED_CONFIG_ID=$(grep "^${SENDER_NAME}:" /tmp/email_account_mappings.txt | cut -d':' -f2)
      if [ -n "$MAPPED_CONFIG_ID" ]; then
        EMAIL_ACCOUNT_ID="$MAPPED_CONFIG_ID"
        echo "Using config_id ${MAPPED_CONFIG_ID} for sender ${SENDER_NAME}"
      else
        echo "No config_id mapping found for sender ${SENDER_NAME}, using name directly"
      fi
    fi
    
    # Check if channel already exists (search by display name)
    EXISTING_CHANNEL=$(curl -X GET \
      ${CA} ${CERT} ${KEY} \
      -s "https://localhost:9200/_plugins/_notifications/configs" | jq -r '.config_list[]? | select(.config.name=="'${CHANNEL_DISPLAY_NAME}'" and .config.config_type=="email") | .config_id')
    
    # Create channel payload
    cat > /tmp/channel_<%= channel['name'] %>.json <<EOF
{
  "config": {
    "name": "${CHANNEL_DISPLAY_NAME}",
    "description": "<%= channel.fetch('description', 'Auto-generated channel') %>",
    "config_type": "<%= channel.fetch('type', 'email') %>",
    "is_enabled": <%= channel.fetch('enabled', true) %>,
    "email": {
      "email_account_id": "${EMAIL_ACCOUNT_ID}",
      "recipient_list": [
      <% channel['users'].each_with_index do |user, index| %>
        <% if index > 0 %>,
      <% end %>  {
          "recipient": "<%= user %>"
        }<% end %>
      ]
      <% if channel['subject'] %>
      ,"subject": "<%= channel['subject'] %>"
      <% end %>
      <% if channel['message'] %>
      ,"message": "<%= channel['message'] %>"
      <% end %>
    }
  }
}
EOF

    echo "Payload for channel <%= channel['name'] %>:"
    cat /tmp/channel_<%= channel['name'] %>.json
    
    if [ -n "$EXISTING_CHANNEL" ]; then
      echo "Updating existing channel <%= channel['name'] %> with config_id: ${EXISTING_CHANNEL}"
      
      # Update the channel using PUT
      CHANNEL_RESPONSE=$(curl -X PUT \
        ${CA} ${CERT} ${KEY} \
        -H "Content-Type: application/json" \
        -d @/tmp/channel_<%= channel['name'] %>.json \
        -s "https://localhost:9200/_plugins/_notifications/configs/${EXISTING_CHANNEL}")
      
      if echo "$CHANNEL_RESPONSE" | jq -e '.config_id' > /dev/null 2>&1; then
        echo "Channel <%= channel['name'] %> updated successfully"
      else
        echo "Failed to update channel: <%= channel['name'] %>"
        echo "Response: $CHANNEL_RESPONSE"
      fi
      
    else
      echo "Creating new notification channel: <%= channel['name'] %>"
      
      # Add id and name fields for POST requests
      jq '. + {"id": "<%= channel['name'] %>", "name": "<%= channel['name'] %>"}' /tmp/channel_<%= channel['name'] %>.json > /tmp/channel_<%= channel['name'] %>_post.json
      
      # Create the channel using POST
      CHANNEL_RESPONSE=$(curl -X POST \
        ${CA} ${CERT} ${KEY} \
        -H "Content-Type: application/json" \
        -d @/tmp/channel_<%= channel['name'] %>_post.json \
        -s "https://localhost:9200/_plugins/_notifications/configs/")
      
      if echo "$CHANNEL_RESPONSE" | jq -e '.config_id' > /dev/null 2>&1; then
        CHANNEL_CONFIG_ID=$(echo "$CHANNEL_RESPONSE" | jq -r '.config_id')
        echo "Channel <%= channel['name'] %> created successfully with config_id: ${CHANNEL_CONFIG_ID}"
      else
        echo "Failed to create channel: <%= channel['name'] %>"
        echo "Response: $CHANNEL_RESPONSE"
      fi
      
      # Clean up POST-specific file
      rm -f /tmp/channel_<%= channel['name'] %>_post.json
    fi
    
    # Clean up temp file
    rm -f /tmp/channel_<%= channel['name'] %>.json
      
    echo "Channel <%= channel['name'] %> configured"
  <% end %>
  
  # Clean up mapping file
  rm -f /tmp/email_account_mappings.txt
<% end %>

exit 0