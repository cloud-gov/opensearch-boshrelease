#!/bin/bash
set -e # exit immediately if a simple command exits with a non-zero status
set -u # report the usage of uninitialized variables

export JOB_NAME=opensearch
export PORT=${PORT:-5000}
export LANG=en_US.UTF-8
export TMP_DIR=/var/vcap/sys/tmp/$JOB_NAME
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export LOG_DIR=/var/vcap/sys/log/$JOB_NAME
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME
export STORE_DIR=/var/vcap/store/$JOB_NAME
export JAVA_HOME="/var/vcap/packages/opensearch/jdk"
export PATH="${JAVA_HOME}/bin:${PATH}"
export OPENSEARCH_HOME=/var/vcap/packages/opensearch
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config

# source /var/vcap/packages/openjdk-21/bosh/runtime.env

<% p("opensearch.exec.environment", {}).each do |k, v| %>
export <%= k %>=<%= v %>
<% end %>

<% if p("opensearch.fips.enabled", false) %>
  FIPS_LIB_DIR="/var/vcap/data/opensearch/fips-lib"
  FIPS_CP=""
  for jar in bc-fips bctls-fips bcutil-fips; do
    src=$(ls ${FIPS_LIB_DIR}/${jar}-*.jar 2>/dev/null | head -n1)
    if [ -z "$src" ]; then 
      echo "ERROR: FIPS enabled but ${jar}-*.jar t found in ${FIPS_LIB_DIR}"
      exit 1
    fi
    FIPS_CP="${FIPS_CP}:${src}"
done
FIPS_CP="${FIPS_CP#:}"
echo "FIPS classpath: ${FIPS_CP}"

export KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"
export OPENSEARCH_KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"
FIPS_KEYSTORE_PATH="/var/vcap/data/opensearch/keystore.bcfks"
FIPS_TRUSTSTORE_PATH="/var/vcap/data/opensearch/truststore.bcfks"
FIPS_STORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"

# Validate password length
if [ ${#FIPS_STORE_PASSWORD} -lt 14 ]; then
    echo "ERROR: FIPS keystore password must be at least 14 characters long"
    exit 1
fi

echo "FIPS_CP=${FIPS_CP}"
for jar in $(echo $FIPS_CP | tr ':' ' '); do
  echo "--- $jar"
  ls -la $jar
  unzip -l $jar | grep "BouncyCastleFipsProvider.class"
done
# Create wrapper function for FIPS-enabled keytool
fips_keytool() {
    CLASSPATH="${FIPS_CP}" ${JAVA_HOME}/bin/keytool \
        -providerclass org.bouncycastle.jcajce.provider.BouncyCastleFipsProvider \
        -providerarg "C:HYBRID;" \
        -Djava.io.tmpdir=/var/vcap/data/ \
         "$@"
}

fips_keystore_add() {
  local key="$1"
  local value="$2"
  printf '%s\n%s\n' "${OPENSEARCH_KEYSTORE_PASSWORD}" "${value}" \
    | ${PACKAGE_DIR}/bin/opensearch-keystore add --stdin --force "${key}"
}


if [ ! -f "$FIPS_KEYSTORE_PATH" ]; then
    echo "Creating FIPS keystore..."
    fips_keytool -genkeypair \
        -alias opensearch-node \
        -keyalg RSA \
        -keysize 2048 \
        -validity 365 \
        -keystore "$FIPS_KEYSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -keypass "$FIPS_STORE_PASSWORD" \
        -dname "CN=<%= spec.address || spec.name %>, O=GSA, C=US"
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create FIPS keystore"
        exit 1
    fi
    echo "FIPS keystore created successfully"

    chown vcap:vcap "$FIPS_KEYSTORE_PATH"
    chmod 600 "$FIPS_KEYSTORE_PATH"
fi

# Create FIPS truststore if it doesn't exist  
if [ ! -f "$FIPS_TRUSTSTORE_PATH" ]; then
    echo "Creating FIPS truststore..."
    
    # Export cert from keystore
    fips_keytool -exportcert \
        -alias opensearch-node \
        -keystore "$FIPS_KEYSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file /tmp/opensearch-cert.pem
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to export certificate from keystore"
        exit 1
    fi
    
    # Import cert to truststore
    fips_keytool -importcert \
        -alias opensearch-ca \
        -keystore "$FIPS_TRUSTSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file /tmp/opensearch-cert.pem \
        -noprompt
    
    if [ $? -ne 0 ]; then
        echo "ERROR: Failed to create FIPS truststore"
        rm -f /tmp/opensearch-cert.pem
        exit 1
    fi
    
    rm -f /tmp/opensearch-cert.pem
    echo "FIPS truststore created successfully"

    chown vcap:vcap "$FIPS_TRUSTSTORE_PATH"
    chmod 600 "$FIPS_TRUSTSTORE_PATH"


fi

<% if_p('opensearch.fips.ca_certificate') do |ca_cert| %>
    # Import provided CA certificate
    echo "Importing provided CA certificate..."
    echo "<%= ca_cert %>" > /tmp/ca-cert.pem

    fips_keytool -importcert \
        -alias provided-ca \
        -keystore "$FIPS_TRUSTSTORE_PATH" \
        -storetype BCFKS \
        -storepass "$FIPS_STORE_PASSWORD" \
        -file ${JOB_DIR}/config/ssl/opensearch.ca \
        -noprompt

    if [ $? -eq 0 ]; then
        echo "CA certificate imported successfully"

        chown vcap:vcap "$FIPS_TRUSTSTORE_PATH"
        chmod 600 "$FIPS_TRUSTSTORE_PATH"
    else
        echo "WARNING: Failed to import CA certificate"
    fi

    rm -f /tmp/ca-cert.pem
    <% end %>


echo "Adding FIPS keystore passwords to OpenSearch keystore..."
# Add passwords
fips_keystore_add "plugins.security.ssl.transport.keystore_password_secure" "$FIPS_STORE_PASSWORD"
fips_keystore_add "plugins.security.ssl.transport.truststore_password_secure" "$FIPS_STORE_PASSWORD"
fips_keystore_add "plugins.security.ssl.http.keystore_password_secure" "$FIPS_STORE_PASSWORD"
fips_keystore_add "plugins.security.ssl.http.truststore_password_secure" "$FIPS_STORE_PASSWORD"
fips_keystore_add "plugins.security.ssl.http.keystore_keypassword_secure" "$FIPS_STORE_PASSWORD"
fips_keystore_add "plugins.security.ssl.transport.keystore_keypassword_secure" "$FIPS_STORE_PASSWORD"
<% end %>

export HEAP_SIZE=$((( $( cat /proc/meminfo | grep MemTotal | awk '{ print $2 }' ) * <%= p("opensearch.heap_percentage") %> ) / 100 ))K
<% if_p('opensearch.heap_size') do |heap_size| %>
  HEAP_SIZE=<%= heap_size %>
<% end %>

# Set heap size and TMP_DIR
export OPENSEARCH_JAVA_OPTS="-Xms$HEAP_SIZE -Xmx$HEAP_SIZE -Djava.io.tmpdir=$TMP_DIR"

<% if p("opensearch.fips.enabled", false) %>
# Add FIPS-specific Java options

export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Djavax.net.ssl.keyStoreType=BCFKS"
export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Djavax.net.ssl.trustStoreType=BCFKS"
echo "FIPS mode enabled for OpenSearch runtime"
<% end %>

export MAX_OPEN_FILES=<%= p("opensearch.limits.fd") %>
export MAX_LOCKED_MEMORY=unlimited  # required to enable opensearch's mlockall setting

ulimit -u 4096
if [ -n "$MAX_OPEN_FILES" ]; then
  ulimit -n $MAX_OPEN_FILES
fi
if [ -n "$MAX_LOCKED_MEMORY" ]; then
  ulimit -l $MAX_LOCKED_MEMORY
fi

<% if p("opensearch.fips.enabled", false) %>
# In FIPS mode, keys should already be in FIPS-compliant format
echo "FIPS mode enabled - using pre-formatted keys from FIPS keystores"


<% else %>
# PKCS8 keys are required for Opensearch TLS (Non-FIPS mode only)
# https://opensearch.org/docs/latest/security/configuration/tls/
<% if_p('opensearch.admin.private_key') do %>
  openssl pkcs8 -v1 "PBE-SHA1-3DES" \
  -in "${JOB_DIR}/config/ssl/opensearch-admin.pem" -topk8 \
  -out "${JOB_DIR}/config/ssl/opensearch-admin.key" -nocrypt
<% end %>
<% if_p('opensearch.node.ssl.private_key') do %>
  openssl pkcs8 -v1 "PBE-SHA1-3DES" \
  -in "${JOB_DIR}/config/ssl/opensearch-node.pem" -topk8 \
  -out "${JOB_DIR}/config/ssl/opensearch-node.key" -nocrypt
  chmod 600 ${JOB_DIR}/config/ssl/opensearch*.key
<% end %>
<% if_p('opensearch.http.ssl.private_key') do %>
  openssl pkcs8 -v1 "PBE-SHA1-3DES" \
  -in "${JOB_DIR}/config/ssl/opensearch-http.pem" -topk8 \
  -out "${JOB_DIR}/config/ssl/opensearch-http.key" -nocrypt
  chmod 600 ${JOB_DIR}/config/ssl/opensearch*.key
<% end %>
<% end %>

# Start OpenSearch with appropriate FIPS mode setting
<% if p("opensearch.fips.enabled", false) %>
OPENSEARCH_FIPS_MODE=true ${OPENSEARCH_HOME}/bin/opensearch \
<% else %>
${OPENSEARCH_HOME}/bin/opensearch \
<% end %>
  <%= p("opensearch.exec.options", []).join(' ') %>