#!/bin/bash
set -e
set -u

export JOB_NAME=opensearch
export PORT=${PORT:-5000}
export LANG=en_US.UTF-8
export TMP_DIR=/var/vcap/sys/tmp/$JOB_NAME
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export LOG_DIR=/var/vcap/sys/log/$JOB_NAME
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME
export STORE_DIR=/var/vcap/store/$JOB_NAME
export JAVA_HOME="/var/vcap/packages/opensearch/jdk"
export PATH="${JAVA_HOME}/bin:${PATH}"
export OPENSEARCH_HOME=/var/vcap/packages/opensearch
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config
export KEYSTORE_PASSWORD=<%= p('opensearch.fips.keystore_password', 'changeme') %>

<% p("opensearch.exec.environment", {}).each do |k, v| %>
export <%= k %>=<%= v %>
<% end %>

<% if p("opensearch.fips.enabled", false) %>
echo "Starting OpenSearch in FIPS mode..."

# Verify required FIPS files exist
FIPS_LIB_DIR="/var/vcap/data/opensearch/fips-lib"
BCFKS_TRUSTSTORE="${OPENSEARCH_PATH_CONF}/truststore.bcfks"
BCFKS_KEYSTORE="${OPENSEARCH_PATH_CONF}/keystore.bcfks"

if [ ! -f "${BCFKS_TRUSTSTORE}" ]; then
  echo "ERROR: BCFKS truststore not found at ${BCFKS_TRUSTSTORE}"
  exit 1
fi

if [ ! -f "${BCFKS_KEYSTORE}" ]; then
  echo "ERROR: BCFKS keystore not found at ${BCFKS_KEYSTORE}"
  exit 1
fi

if [ ! -f "${OPENSEARCH_PATH_CONF}/fips.security" ]; then
  echo "ERROR: FIPS security properties not found"
  exit 1
fi

# Verify FIPS JARs exist
for jar in bc-fips bctls-fips bcpkix-fips bcutil-fips; do
  if ! ls ${FIPS_LIB_DIR}/${jar}-*.jar 1>/dev/null 2>&1; then
    echo "ERROR: FIPS JAR ${jar} not found in ${FIPS_LIB_DIR}"
    exit 1
  fi
done

echo "✓ All FIPS files validated"
export OPENSEARCH_FIPS_MODE=true

<% else %>
echo "Starting OpenSearch in standard mode..."
<% end %>

# Set heap size
export HEAP_SIZE=$((( $( cat /proc/meminfo | grep MemTotal | awk '{ print $2 }' ) * <%= p("opensearch.heap_percentage") %> ) / 100 ))K
<% if_p('opensearch.heap_size') do |heap_size| %>
HEAP_SIZE=<%= heap_size %>
<% end %>

# Set basic JVM options (FIPS options are in jvm.options file)
export OPENSEARCH_JAVA_OPTS="-Xms$HEAP_SIZE -Xmx$HEAP_SIZE \
                             -Dorg.bouncycastle.fips.approved_only=false \
                             -Djava.security.properties=${OPENSEARCH_PATH_CONF}/fips.security \
                             -Djavax.net.ssl.keyStoreType=BCFKS \
                             -Djavax.net.ssl.trustStoreType=BCFKS \
                             -XX:-UsePerfData \
                             -Dnet.bytebuddy.agent.disabled=true \
                             -Djava.io.tmpdir=$TMP_DIR"

# Set system limits
export MAX_OPEN_FILES=<%= p("opensearch.limits.fd") %>
export MAX_LOCKED_MEMORY=unlimited
ulimit -u 4096
if [ -n "$MAX_OPEN_FILES" ]; then
  ulimit -n $MAX_OPEN_FILES
fi
if [ -n "$MAX_LOCKED_MEMORY" ]; then
  ulimit -l $MAX_LOCKED_MEMORY
fi

# TLS Certificate Key Conversion
<% if p("opensearch.fips.enabled", false) %>
# FIPS Mode: Convert keys to PKCS8
<% if_p('opensearch.admin.private_key') do %>
openssl pkcs8 -topk8 \
  -in "${JOB_DIR}/config/ssl/opensearch-admin.pem" \
  -out "${JOB_DIR}/config/ssl/opensearch-admin.key" \
  -nocrypt
chmod 600 ${JOB_DIR}/config/ssl/opensearch-admin.key
<% end %>

<% if_p('opensearch.node.ssl.private_key') do %>
openssl pkcs8 -topk8 \
  -in "${JOB_DIR}/config/ssl/opensearch-node.pem" \
  -out "${JOB_DIR}/config/ssl/opensearch-node.key" \
  -nocrypt
chmod 600 ${JOB_DIR}/config/ssl/opensearch-node.key
<% end %>

<% if_p('opensearch.http.ssl.private_key') do %>
openssl pkcs8 -topk8 \
  -in "${JOB_DIR}/config/ssl/opensearch-http.pem" \
  -out "${JOB_DIR}/config/ssl/opensearch-http.key" \
  -nocrypt
chmod 600 ${JOB_DIR}/config/ssl/opensearch-http.key
<% end %>

<% else %>
# Non-FIPS Mode
<% if_p('opensearch.admin.private_key') do %>
openssl pkcs8 -v1 "PBE-SHA1-3DES" \
  -in "${JOB_DIR}/config/ssl/opensearch-admin.pem" -topk8 \
  -out "${JOB_DIR}/config/ssl/opensearch-admin.key" -nocrypt
<% end %>

<% if_p('opensearch.node.ssl.private_key') do %>
openssl pkcs8 -v1 "PBE-SHA1-3DES" \
  -in "${JOB_DIR}/config/ssl/opensearch-node.pem" -topk8 \
  -out "${JOB_DIR}/config/ssl/opensearch-node.key" -nocrypt
chmod 600 ${JOB_DIR}/config/ssl/opensearch*.key
<% end %>

<% if_p('opensearch.http.ssl.private_key') do %>
openssl pkcs8 -v1 "PBE-SHA1-3DES" \
  -in "${JOB_DIR}/config/ssl/opensearch-http.pem" -topk8 \
  -out "${JOB_DIR}/config/ssl/opensearch-http.key" -nocrypt
chmod 600 ${JOB_DIR}/config/ssl/opensearch*.key
<% end %>
<% end %>

# Start OpenSearch
${OPENSEARCH_HOME}/bin/opensearch <%= p("opensearch.exec.options", []).join(' ') %>