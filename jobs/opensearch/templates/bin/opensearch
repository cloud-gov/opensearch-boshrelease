#!/bin/bash
set -e # exit immediately if a simple command exits with a non-zero status
set -u # report the usage of uninitialized variables

export JOB_NAME=opensearch
export PORT=${PORT:-5000}
export LANG=en_US.UTF-8

export TMP_DIR=/var/vcap/sys/tmp/$JOB_NAME
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export LOG_DIR=/var/vcap/sys/log/$JOB_NAME
export PACKAGE_DIR=/var/vcap/packages/$JOB_NAME
export STORE_DIR=/var/vcap/store/$JOB_NAME

export JAVA_HOME="/var/vcap/packages/opensearch/jdk"
export PATH="${JAVA_HOME}/bin:${PATH}"

export OPENSEARCH_HOME=/var/vcap/packages/opensearch
export OPENSEARCH_PATH_CONF=${JOB_DIR}/config

# source /var/vcap/packages/openjdk-21/bosh/runtime.env

<% p("opensearch.exec.environment", {}).each do |k, v| %>
export <%= k %>=<%= v %>
<% end %>

<% if p("opensearch.fips.enabled", false) %>
  FIPS_LIB_DIR="/var/vcap/data/opensearch/fips-lib"
  BCFKS_TRUSTSTORE="/var/vcap/data/opensearch/truststore.bcfks"
  BCFKS_KEYSTORE="/var/vcap/data/opensearch/keystore.bcfks"
  KEYSTORE_PASS_FILE="${OPENSEARCH_PATH_CONF}/.keystore.pass"
  
  # Verify BCFKS stores exist
  if [ ! -f "${BCFKS_TRUSTSTORE}" ]; then
    echo "ERROR: BCFKS truststore not found at ${BCFKS_TRUSTSTORE}"
    echo "Ensure pre-start script ran successfully"
    exit 1
  fi
  
  if [ ! -f "${BCFKS_KEYSTORE}" ]; then
    echo "ERROR: BCFKS keystore not found at ${BCFKS_KEYSTORE}"
    echo "Ensure pre-start script ran successfully"
    exit 1
  fi
  
  # Build FIPS classpath
  FIPS_CP=""
  for jar in bc-fips bctls-fips bcpkix-fips bcutil-fips; do
    src=$(ls ${FIPS_LIB_DIR}/${jar}-*.jar 2>/dev/null | head -n1)
    if [ -n "$src" ]; then
      FIPS_CP="${FIPS_CP}:${src}"
    fi
  done
  FIPS_CP="${FIPS_CP#:}"
  
  echo "FIPS classpath: ${FIPS_CP}"
<% end %>

export HEAP_SIZE=$((( $( cat /proc/meminfo | grep MemTotal | awk '{ print $2 }' ) * <%= p("opensearch.heap_percentage") %> ) / 100 ))K

<% if_p('opensearch.heap_size') do |heap_size| %>
  HEAP_SIZE=<%= heap_size %>
<% end %>

# Set heap size and TMP_DIR
export OPENSEARCH_JAVA_OPTS="-Xms$HEAP_SIZE -Xmx$HEAP_SIZE -Djava.io.tmpdir=/var/vcap/data/opensearch/"

<% if p("opensearch.fips.enabled", false) %>
  # FIPS Mode Java Security Configuration
  export OPENSEARCH_KEYSTORE_PASSWORD="<%= p('opensearch.fips.keystore_password', 'changeme') %>"
  
  # Set BCFKS (Bouncy Castle FIPS Keystore) as the keystore/truststore type
  export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Djavax.net.ssl.keyStoreType=BCFKS"
  export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Djavax.net.ssl.trustStoreType=BCFKS"
  
  # Add Bouncy Castle FIPS provider to classpath
  export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Xbootclasspath/a:${FIPS_CP}"
  
  # Configure security providers (Bouncy Castle FIPS)
  export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Dorg.bouncycastle.fips.approved_only=true"
  # Disable non-FIPS compliant algorithms
  export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Dcom.sun.net.ssl.checkRevocation=true"
  
  # Optional: Enable FIPS debug logging
  <% if p("opensearch.fips.debug", false) %>
  export OPENSEARCH_JAVA_OPTS="$OPENSEARCH_JAVA_OPTS -Djava.security.debug=provider"
  <% end %>
  
  echo "FIPS mode enabled for OpenSearch runtime"
<% end %>

export MAX_OPEN_FILES=<%= p("opensearch.limits.fd") %>
export MAX_LOCKED_MEMORY=unlimited  # required to enable opensearch's mlockall setting

ulimit -u 4096

if [ -n "$MAX_OPEN_FILES" ]; then
  ulimit -n $MAX_OPEN_FILES
fi

if [ -n "$MAX_LOCKED_MEMORY" ]; then
  ulimit -l $MAX_LOCKED_MEMORY
fi

# TLS Certificate Key Conversion
# PKCS8 keys are required for OpenSearch TLS
# https://opensearch.org/docs/latest/security/configuration/tls/

<% if p("opensearch.fips.enabled", false) %>
  # FIPS Mode: Convert keys to PKCS8 using FIPS-compliant algorithms
  # Use AES-256-CBC instead of legacy PBE-SHA1-3DES
  
  <% if_p('opensearch.admin.private_key') do %>
    openssl pkcs8 -topk8 \
      -in "${JOB_DIR}/config/ssl/opensearch-admin.pem" \
      -out "${JOB_DIR}/config/ssl/opensearch-admin.key" \
      -nocrypt
    chmod 600 ${JOB_DIR}/config/ssl/opensearch-admin.key
  <% end %>

  <% if_p('opensearch.node.ssl.private_key') do %>
    openssl pkcs8 -topk8 \
      -in "${JOB_DIR}/config/ssl/opensearch-node.pem" \
      -out "${JOB_DIR}/config/ssl/opensearch-node.key" \
      -nocrypt
    chmod 600 ${JOB_DIR}/config/ssl/opensearch-node.key
  <% end %>

  <% if_p('opensearch.http.ssl.private_key') do %>
    openssl pkcs8 -topk8 \
      -in "${JOB_DIR}/config/ssl/opensearch-http.pem" \
      -out "${JOB_DIR}/config/ssl/opensearch-http.key" \
      -nocrypt
    chmod 600 ${JOB_DIR}/config/ssl/opensearch-http.key
  <% end %>

<% else %>
  # Non-FIPS Mode: Use legacy PBE-SHA1-3DES for PKCS8 conversion
  
  <% if_p('opensearch.admin.private_key') do %>
    openssl pkcs8 -v1 "PBE-SHA1-3DES" \
      -in "${JOB_DIR}/config/ssl/opensearch-admin.pem" -topk8 \
      -out "${JOB_DIR}/config/ssl/opensearch-admin.key" -nocrypt
  <% end %>

  <% if_p('opensearch.node.ssl.private_key') do %>
    openssl pkcs8 -v1 "PBE-SHA1-3DES" \
      -in "${JOB_DIR}/config/ssl/opensearch-node.pem" -topk8 \
      -out "${JOB_DIR}/config/ssl/opensearch-node.key" -nocrypt
    chmod 600 ${JOB_DIR}/config/ssl/opensearch*.key
  <% end %>

  <% if_p('opensearch.http.ssl.private_key') do %>
    openssl pkcs8 -v1 "PBE-SHA1-3DES" \
      -in "${JOB_DIR}/config/ssl/opensearch-http.pem" -topk8 \
      -out "${JOB_DIR}/config/ssl/opensearch-http.key" -nocrypt
    chmod 600 ${JOB_DIR}/config/ssl/opensearch*.key
  <% end %>
<% end %>

# Start OpenSearch with appropriate FIPS mode setting
<% if p("opensearch.fips.enabled", false) %>
  export OPENSEARCH_FIPS_MODE=true
  
  echo "Starting OpenSearch in FIPS mode..."
  echo "  BCFKS Keystore Type: enabled"
  echo "  FIPS Approved Only: true"
  
  KEYSTORE_PASS_FILE="${OPENSEARCH_PATH_CONF}/.keystore.pass"
  
  if [ -f "${KEYSTORE_PASS_FILE}" ]; then
    echo "Reading keystore password from file..."
    cat "${KEYSTORE_PASS_FILE}" | ${OPENSEARCH_HOME}/bin/opensearch \
      <%= p("opensearch.exec.options", []).join(' ') %>
  else
    echo "ERROR: Keystore password file not found at ${KEYSTORE_PASS_FILE}"
    echo "Ensure pre-start script ran successfully."
    exit 1
  fi
<% else %>
  ${OPENSEARCH_HOME}/bin/opensearch \
    <%= p("opensearch.exec.options", []).join(' ') %>
<% end %>

select DATE_TRUNC('month', created_at) AS month_start, sum(amount_microcredits) AS sum_microcredits, sum(amount_microcredits) / POWER(10, 6) AS sum_credits
from measurement
join resource on measurement.resource_natural_id = resource.natural_id
join reading on reading.id = measurement.reading_id
where cf_org_id = 'd7843b4a-5973-4f8c-b067-6d40807fcf0d'
group by DATE_TRUNC('month', created_at)
order by month_start;
