## JVM configuration
################################################################
## IMPORTANT: JVM heap size
################################################################
##
## You should always set the min and max JVM heap
## size to the same value. For example, to set
## the heap to 4 GB, set:
##
## -Xms4g
## -Xmx4g
##
## See https://opensearch.org/docs/opensearch/install/important-settings/
## for more information
##
################################################################

# Xms represents the initial size of total heap space
# Xmx represents the maximum size of total heap space

#-Xms2g
#-Xmx2g

################################################################
## Expert settings
################################################################
##
## All settings below this section are considered
## expert settings. Don't tamper with them unless
## you understand what you are doing
##
################################################################

## GC configuration
-XX:+UseG1GC
-XX:G1ReservePercent=25
-XX:InitiatingHeapOccupancyPercent=30

## Essential options
-XX:+HeapDumpOnOutOfMemoryError
-javaagent:agent/opensearch-agent.jar

## Fix warnings for Java 21+
--add-opens=java.base/java.nio=ALL-UNNAMED
--add-opens=java.base/sun.nio.ch=ALL-UNNAMED
--add-modules=jdk.incubator.vector
--enable-native-access=ALL-UNNAMED

## Suppress unsafe warnings (for ByteBuddy)
--add-opens=java.base/sun.misc=ALL-UNNAMED

## Optimizations
-Dfile.encoding=UTF-8
-Djna.nosys=true
-Dlog4j.shutdownHookEnabled=false
-Dlog4j2.disable.jmx=true
-Dlog4j.skipJansi=true
-XX:-UsePerfData
-Djava.io.tmpdir=/var/vcap/data/opensearch/

<% if p("opensearch.fips.enabled", false) %>
################################################################
## FIPS Configuration with Security Plugin Support
################################################################
# FIPS Security Properties - MUST be first
-Djava.security.properties=/var/vcap/jobs/opensearch/config/fips.security

# BouncyCastle FIPS Provider Configuration
-Dorg.bouncycastle.fips.approved_only=<%= p('opensearch.fips.strict', false) %>

# CRITICAL: Add FIPS JARs to classpath
-Xbootclasspath/a:/var/vcap/data/opensearch/fips-lib/bc-fips-2.1.2.jar:/var/vcap/data/opensearch/fips-lib/bctls-fips-2.1.20.jar:/var/vcap/data/opensearch/fips-lib/bcpkix-fips-2.1.9.jar:/var/vcap/data/opensearch/fips-lib/bcutil-fips-2.1.4.jar

# FIPS Trust Store Configuration  
-Djavax.net.ssl.trustStore=/var/vcap/jobs/opensearch/config/truststore.bcfks
-Djavax.net.ssl.trustStoreType=BCFKS
-Djavax.net.ssl.trustStoreProvider=BCFIPS
-Djavax.net.ssl.trustStorePassword=<%= p('opensearch.fips.keystore_password', 'changeme') %>

# FIPS Key Store Configuration
-Djavax.net.ssl.keyStore=/var/vcap/jobs/opensearch/config/keystore.bcfks
-Djavax.net.ssl.keyStoreType=BCFKS
-Djavax.net.ssl.keyStoreProvider=BCFIPS
-Djavax.net.ssl.keyStorePassword=<%= p('opensearch.fips.keystore_password', 'changeme') %>

# Protocol and cipher configuration
-Dhttps.protocols=TLSv1.2,TLSv1.3
-Djdk.tls.client.protocols=TLSv1.2,TLSv1.3
-Djdk.tls.server.protocols=TLSv1.2,TLSv1.3

# Additional FIPS compliance
-Dcom.sun.net.ssl.checkRevocation=false
-Dcom.redhat.fips=false
-Djsse.enableSNIExtension=true

<% if p("opensearch.fips.debug", false) %>
# FIPS Debug logging
-Djava.security.debug=provider,engine,keymanager,trustmanager
<% end %>

<% end %>

# Other optimizations
-Dnet.bytebuddy.agent.disabled=true

<% p('opensearch.jvm_options').each do |opt| %>
<%= opt %>
<% end %>