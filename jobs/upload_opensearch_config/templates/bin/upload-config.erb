#!/bin/bash
set -ex
export JOB_NAME=upload_opensearch_config
export JOB_DIR=/var/vcap/jobs/$JOB_NAME
export DATA_DIR=/var/vcap/data/$JOB_NAME
<%
opensearch_host = p("opensearch_config.opensearch.host")
opensearch_port = p("opensearch_config.opensearch.port")
aliases = p("opensearch_config.alias","")
metric_aliases = p("opensearch_config.metric_alias","")
platform_aliases = p("opensearch_config.platform_alias","")
%>
# OIDC Configuration
<% if_link("opensearch") do |opensearch_config| %>
  <% opensearch_config.if_p('opensearch.oidc.token_url') do %>
    <% opensearch_config.if_p('opensearch.oidc.client_id') do %>
OIDC_CLIENT_ID="<%= opensearch_config.p('opensearch.oidc.client_id') %>"
    <% end %>
    <% opensearch_config.if_p('opensearch.oidc.client_secret') do %>
OIDC_CLIENT_SECRET="<%= opensearch_config.p('opensearch.oidc.client_secret') %>"
    <% end %>
OIDC_TOKEN_URL="<%= opensearch_config.p('opensearch.oidc.token_url') %>"
OIDC_ENABLED=true
  <% end.else do %>
OIDC_ENABLED=false
  <% end %>
<% end.else do %>
OIDC_ENABLED=false
<% end %>

# Function to get OIDC token
get_oidc_token() {
    local token_url=$1
    local client_id=$2
    local client_secret=$3
    local scope=$4
    
    if [[ -z "$token_url" || -z "$client_id" || -z "$client_secret" ]]; then
        echo "Error: Missing required OIDC parameters" >&2
        return 1
    fi
    
    local token_data="grant_type=client_credentials&client_id=${client_id}&client_secret=${client_secret}"
    if [[ -n "$scope" ]]; then
        token_data="${token_data}&scope=${scope}"
    fi
    
    echo "Requesting OIDC token from: ${token_url}" >&2
    
    local response=$(curl -s -X POST \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "${token_data}" \
        "${token_url}")
    
    if [[ $? -ne 0 ]]; then
        echo "Error: Failed to get OIDC token" >&2
        return 1
    fi
    
    local access_token=$(echo "$response" | grep -o '"access_token":"[^"]*"' | cut -d'"' -f4)
    
    if [[ -z "$access_token" ]]; then
        echo "Error: No access token received from token endpoint" >&2
        echo "Token response: $response" >&2
        return 1
    fi
    
    echo "Successfully obtained OIDC token" >&2
    echo "$access_token"
    return 0
}

# Get OIDC token if enabled
OIDC_TOKEN=""
AUTH_HEADER=""
if [[ "$OIDC_ENABLED" == "true" && -n "$OIDC_TOKEN_URL" && -n "$OIDC_CLIENT_ID" && -n "$OIDC_CLIENT_SECRET" ]]; then
    echo "OIDC is enabled, attempting to get token..."
    
    # Try with 'uaa.none' scope first, then without scope
    OIDC_TOKEN=$(get_oidc_token "$OIDC_TOKEN_URL" "$OIDC_CLIENT_ID" "$OIDC_CLIENT_SECRET" "uaa.none")
    if [[ $? -ne 0 || -z "$OIDC_TOKEN" ]]; then
        echo "Retrying OIDC token without scope..."
        OIDC_TOKEN=$(get_oidc_token "$OIDC_TOKEN_URL" "$OIDC_CLIENT_ID" "$OIDC_CLIENT_SECRET")
        if [[ $? -ne 0 || -z "$OIDC_TOKEN" ]]; then
            echo "Error: Failed to obtain OIDC token after multiple attempts. Exiting." >&2
            exit 1
        fi
    fi
    
    AUTH_HEADER="-H \"Authorization: Bearer ${OIDC_TOKEN}\""
    echo "OIDC token obtained successfully"
elif [[ "$OIDC_ENABLED" == "true" ]]; then
    echo "Error: OIDC is enabled but missing required configuration (token_url, client_id, or client_secret)" >&2
    exit 1
else
    echo "OIDC is disabled, proceeding without token authentication"
fi

# Delete existing templates before uploading
URL=https://<%= opensearch_host %>:<%= opensearch_port %>
BASEURL=https://<%= opensearch_host %>:<%= opensearch_port %>
CA="--cacert ${JOB_DIR}/config/ssl/opensearch.ca"
CERT="--cert ${JOB_DIR}/config/ssl/opensearch-admin.crt"
KEY="--key ${JOB_DIR}/config/ssl/opensearch-admin.key"
ALIAS=<%= aliases %>
METRIC_ALIAS=<%= metric_aliases %>
PLATFORM_ALIAS=<%= platform_aliases %>

for template in $(curl -s ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${URL}/_cat/templates | awk '{print $1}'); do
  if ! grep -qw ${template} <(echo "<%= p('opensearch_config.index_templates').map { |template| template.keys.first }.join(' ') %>"); then
    # hit template and index_template so we can try for legacy and component templates
    curl -s -XDELETE ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${URL}/_template/${template}
    curl -s -XDELETE ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${URL}/_index_template/${template}
  fi
done

<%
require 'uri'
def put_to_es(url_stem_base, es_config, request_params = {})
  ret = []
  es_config = Array(es_config)
  es_config.each do |config|
    if config.is_a? Hash
      ckey, content = config.to_a.first
    else
      ckey = ''
      content = config
    end
    if url_stem_base == ''
      url_stem = "#{ckey}".chomp('/')
    else
      url_stem = "#{url_stem_base}/#{ckey}".chomp('/')
    end
    if request_params.keys.any?
      params = URI.encode_www_form(request_params)
      url_stem << "?#{params}"
    end
    opensearch_host = p("opensearch_config.opensearch.host")
    opensearch_port = p("opensearch_config.opensearch.port")
    ret << "URL=https://#{opensearch_host}:#{opensearch_port}/#{url_stem}"
    if nil == content
     ret << 'curl -X DELETE ${CA} ${CERT} ${KEY} ${AUTH_HEADER} "${URL}"'
    else
      if content.start_with? '/var/vcap'
        ret << "CONTENT_PATH=\"#{content}\""
      else
        ret << <<BASH
CONTENT_PATH=${DATA_DIR}/opensearch_config-http_body.txt
cat <<EOF > ${CONTENT_PATH}
#{content}
EOF
BASH
      end
      ret << <<BASH
HTTP_CODE=$(curl -s -H 'Content-Type: application/json' -w '%{http_code}' -o ${DATA_DIR}/opensearch_config-response.txt -X PUT --data-binary @${CONTENT_PATH} ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${URL})
if grep --quiet "\"errors\":true" ${DATA_DIR}/opensearch_config-response.txt ; then
  cat ${DATA_DIR}/opensearch_config-response.txt >> /dev/stderr
  exit $HTTP_CODE
fi
if [ "$HTTP_CODE" -le "300" ]; then
  cat ${DATA_DIR}/opensearch_config-response.txt
else
  cat ${DATA_DIR}/opensearch_config-response.txt >> /dev/stderr
  exit $HTTP_CODE
fi
BASH
    end
  end #loop
  ret.join("\n")
end
%>

#
# wait for opensearch availability
#
until curl -f ${KEY} ${CERT} ${CA} ${AUTH_HEADER} "${URL}/_cluster/health?wait_for_status=yellow&timeout=10m"; do :; done

echo "--- Component Templates"
<%= put_to_es('_component_template', p('opensearch_config.component_templates')) %>

echo "--- Index Templates"
<%= put_to_es('_index_template', p('opensearch_config.index_templates')) %>

echo "--- Documents"
<%= put_to_es('', p('opensearch_config.docs')) %>

echo "--- License"
<% if_p("opensearch_config.license") do |license| %>
  <%= put_to_es('_license', license, acknowledge: true) %>
<% end %>

echo "--- Creating ISM policy"
<% if_link("opensearch") do |opensearch| %>
  <% if opensearch.p('opensearch.deployment_type').include?('app') %>
    logs_app_rollover_policy=$(curl -XGET ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_plugins/_ism/policies/logs-app-rollover_policy)
    TERM=$(echo "$logs_app_rollover_policy" | grep -o '"_primary_term":[0-9]*' | sed 's/"_primary_term"://')
    SEQ=$(echo "$logs_app_rollover_policy" | grep -o '"_seq_no":[0-9]*' | sed 's/"_seq_no"://')
    if [[ -n "$TERM" ]]; then
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} "${BASEURL}/_plugins/_ism/policies/logs-app-rollover_policy?if_seq_no=${SEQ}&if_primary_term=${TERM}" -H 'Content-Type: application/json' -d @${JOB_DIR}/config/ism-policy.json
    else
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_plugins/_ism/policies/logs-app-rollover_policy -H 'Content-Type: application/json' -d @${JOB_DIR}/config/ism-policy.json
    fi
    HTTP_CODE=$(curl -s -o /dev/null -s -w "%{http_code}\n" -I ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_alias/${ALIAS}/)
    if [ "$HTTP_CODE" -ge "201" ]; then
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/%3Clogs-app-%7Bnow%2Fd%7D-01%3E -H 'Content-Type: application/json' -d'{"aliases": {"'${ALIAS}'": {}}}'
    fi
  <% end %>
  <% if opensearch.p('opensearch.deployment_type').include?('metric') %>
    logs_metric_rollover_policy=$(curl -XGET ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_plugins/_ism/policies/logs-metric-rollover_policy)
    TERM=$(echo "$logs_metric_rollover_policy" | grep -o '"_primary_term":[0-9]*' | sed 's/"_primary_term"://')
    SEQ=$(echo "$logs_metric_rollover_policy" | grep -o '"_seq_no":[0-9]*' | sed 's/"_seq_no"://')
    if [[ -n "$TERM" ]]; then
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} "${BASEURL}/_plugins/_ism/policies/logs-metric-rollover_policy?if_seq_no=${SEQ}&if_primary_term=${TERM}" -H 'Content-Type: application/json' -d @${JOB_DIR}/config/ism-policy-metrics.json
    else
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_plugins/_ism/policies/logs-metric-rollover_policy -H 'Content-Type: application/json' -d @${JOB_DIR}/config/ism-policy-metrics.json
    fi
    HTTP_CODE=$(curl -s -o /dev/null -s -w "%{http_code}\n" -I ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_alias/${METRIC_ALIAS}/)
    if [ "$HTTP_CODE" -ge "201" ]; then
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/%3Clogs-metrics-%7Bnow%2Fd%7D-01%3E -H 'Content-Type: application/json' -d'{"aliases": {"'${METRIC_ALIAS}'": {}}}'
    fi
  <% end %>
  <% if opensearch.p('opensearch.deployment_type').include?('platform') %>
    logs_platform_rollover_policy=$(curl -XGET ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_plugins/_ism/policies/logs-platform-rollover_policy)
    TERM=$(echo "$logs_platform_rollover_policy" | grep -o '"_primary_term":[0-9]*' | sed 's/"_primary_term"://')
    SEQ=$(echo "$logs_platform_rollover_policy" | grep -o '"_seq_no":[0-9]*' | sed 's/"_seq_no"://')
    if [[ -n "$TERM" ]]; then
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} "${BASEURL}/_plugins/_ism/policies/logs-platform-rollover_policy?if_seq_no=${SEQ}&if_primary_term=${TERM}" -H 'Content-Type: application/json' -d @${JOB_DIR}/config/ism-policy-platform.json
    else
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_plugins/_ism/policies/logs-platform-rollover_policy -H 'Content-Type: application/json' -d @${JOB_DIR}/config/ism-policy-platform.json
    fi
    HTTP_CODE=$(curl -s -o /dev/null -s -w "%{http_code}\n" -I ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/_alias/${PLATFORM_ALIAS}/)
    if [ "$HTTP_CODE" -ge "201" ]; then
      curl -XPUT ${CA} ${CERT} ${KEY} ${AUTH_HEADER} ${BASEURL}/%3Clogs-platform-%7Bnow%2Fd%7D-01%3E -H 'Content-Type: application/json' -d'{"aliases": {"'${PLATFORM_